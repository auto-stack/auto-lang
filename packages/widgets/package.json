{
  "name": "@auto-ui/widgets",
  "version": "0.1.0",
  "description": "AutoUI-generated Vue 3 component primitives (reka-ui + Tailwind).",
  "type": "module",
  "license": "MIT",
  "bin": {
    "auto-ui": "./cli/dist/index.js"
  },
  "scripts": {
    "build:cli": "tsc -p cli/tsconfig.json",
    "build:css": "node build-styles.cjs",
    "build": "npm run build:css && npm run build:cli"
  },
  "files": [
    "registry",
    "dist",
    "cli/dist",
    "README.md",
    "LICENSE",
    "NOTICES"
  ],
  "exports": {
    "./styles.css": "./dist/styles.css",
    "./registry/*": "./registry/*/index.ts"
  },
  "peerDependencies": {
    "vue": "^3.4.0",
    "reka-ui": "^2.0.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.0"
  },
  "peerDependenciesMeta": {
    "reka-ui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.3.0"
  }
}
