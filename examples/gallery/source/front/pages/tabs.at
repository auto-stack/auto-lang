// pages/tabs.at - Tabs component documentation page

widget TabsPage {
    model { activeTab str = "preview" }

    view {
        col {
            h1 "Tabs"
            text "A set of layered sections of content, known as tab panels, that display one panel of content at a time."

            h2 "Installation"
            codeblock (lang: "bash", code: "npx shadcn-vue@latest add tabs") {}

            h2 "Simple"
            preview-card (id: "tabs-basic") {
                tabs (default: "account", style: "w-64") {
                    tabs-list {
                        tabs-trigger (text: "Account", value: "account") {}
                        tabs-trigger (text: "Password", value: "password") {}
                    }
                    tabs-content (value: "account") {
                        text "Make changes to your account here."
                    }
                    tabs-content (value: "password") {
                        text "Change your password here."
                    }
                }
            }

            h2 "Properties"
            table {
                thead {
                    tr {
                        th "Property"
                        th "Type"
                        th "Default"
                        th "Values"
                        th "Description"
                    }
                }
                tbody {
                    tr {
                        td "default"
                        td "string"
                        td "-"
                        td "-"
                        td "Default active tab value"
                    }
                    tr {
                        td "value"
                        td "string"
                        td "-"
                        td "-"
                        td "Tab trigger/content value"
                    }
                }
            }
        }
    }
}
