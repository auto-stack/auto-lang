// pages/dropdownmenu.at - DropdownMenu component documentation page

widget DropdownmenuPage {
    model { activeTab str = "preview" }

    view {
        col {
            h1 "DropdownMenu"
            text "A menu that drops down from a trigger element."

            h2 "Installation"
            codeblock (lang: "bash", code: "npx shadcn-vue@latest add dropdown-menu") {}

            h2 "Simple"
            preview-card (id: "dropdownmenu-basic") {
                row (gap: "4") {
                    dropdown-menu {
                        dropdown-menu-trigger {
                            button (text: "Open", variant: "outline") {}
                        }
                        dropdown-menu-content {
                            dropdown-menu-item "Profile"
                            dropdown-menu-item "Billing"
                            dropdown-menu-item "Settings"
                            dropdown-menu-item "Keyboard shortcuts"
                            dropdown-menu-separator {}
                            dropdown-menu-item "Team"
                            dropdown-menu-item "New Team"
                            dropdown-menu-separator {}
                            dropdown-menu-item "Log out"
                        }
                    }
                }
            }

            h2 "Properties"
            table {
                thead {
                    tr {
                        th "Property"
                        th "Type"
                        th "Default"
                        th "Values"
                        th "Description"
                    }
                }
                tbody {
                    tr {
                        td "text"
                        td "string"
                        td "-"
                        td "-"
                        td "Menu item text"
                    }
                    tr {
                        td "disabled"
                        td "boolean"
                        td "false"
                        td "true, false"
                        td "Disables the menu item"
                    }
                    tr {
                        td "shortcut"
                        td "string"
                        td "-"
                        td "-"
                        td "Keyboard shortcut hint"
                    }
                }
            }
        }
    }
}
