                    }
                    table-row {
                        table-cell (text: "getFilteredRowModel", style: "font-mono text-sm") {}
                        table-cell "Returns filtered row model"
                    }
                }
            }

            h2 "Documentation"
            text (text: "For the complete guide with code examples, see the shadcn-vue Data Table documentation.", style: "text-muted-foreground") {}
        }
    }
}
