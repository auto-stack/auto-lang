// components/command.at - Command component

/// Command component for searchable command menus (Command+K palette).
///
/// # Features
/// - Searchable options
/// - Keyboard navigation
/// - Grouped results
/// - Empty state
///
/// # Usage
/// ```
/// command-dialog {
///     command-input (placeholder: "Search...") {}
///     command-list {
///         command-empty | No results
///         command-group (heading: "Suggestions") {
///             command-item | Calendar
///             command-item | Settings
///         }
///     }
/// }
/// ```

widget Command {
    model {
        class str = ""
    }

    view {
        div { style: f"command ${.class}" }
    }
}

/// Command dialog wrapper
widget CommandDialog {
    model {
        open bool = false
    }

    view {
        div { style: "command-dialog" }
    }
}

/// Command input field
widget CommandInput {
    model {
        placeholder str = "Type a command or search..."
        value str = ""
    }

    view {
        div { style: "flex items-center border-b px-3" } {
            text (text: "🔍", style: "mr-2 h-4 w-4 shrink-0 opacity-50") {}
            input { style: "flex h-10 w-full rounded-md bg-transparent py-3 text-sm outline-none placeholder:text-muted-foreground disabled:cursor-not-allowed disabled:opacity-50", placeholder: .placeholder, value: .value }
        }
    }
}

/// Command list container
widget CommandList {
    model {
        maxheight int = 300
    }

    view {
        div { style: "command-list", "max-height": f"${.maxheight}px" }
    }
}

/// Command empty state
widget CommandEmpty {
    model {
        text str = "No results found."
    }

    view {
        p { style: "py-6 text-center text-sm", text: .text }
    }
}

/// Command group
widget CommandGroup {
    model {
        heading str = ""
    }

    view {
        div { style: "command-group" } {
            if .heading != "" {
                div { style: "command-group-heading", text: .heading }
            }
        }
    }
}

/// Command item/option
widget CommandItem {
    msg Msg { Click }

    model {
        text str = ""
        shortcut str = ""
    }

    view {
        div { style: "command-item", onclick: .Click } {
            text (text: .text) {}
            if .shortcut != "" {
                text (text: .shortcut, style: "command-shortcut") {}
            }
        }
    }
}

/// Command separator
widget CommandSeparator {
    view {
        div { style: "command-separator" }
    }
}

/// Demo widget for Command documentation
widget CommandDemo {
    view {
        Command {
            CommandInput (placeholder: "Search commands...") {}
            CommandList {
                CommandEmpty | No commands found.
                CommandGroup (heading: "Suggestions") {
                    CommandItem (text: "Calendar", shortcut: "⌘C") {}
                    CommandItem (text: "Search Emoji", shortcut: "⌘E") {}
                    CommandItem (text: "Calculator", shortcut: "⌘K") {}
                }
                CommandSeparator {}
                CommandGroup (heading: "Settings") {
                    CommandItem | Profile
                    CommandItem | Billing
                    CommandItem | Settings
                }
            }
        }
    }
}
