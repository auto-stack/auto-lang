// source/back/db.at - Notes Database Service
// In-memory storage with JSON file persistence

use api: Note

// Folder type (also defined in api.at for frontend; duplicated here to
// avoid circular import issues with collect_module_imports).
type Folder {
    id int
    name str
    icon str
}

// ═══════════════════════════════════════════════════════════
// In-memory storage
// ═══════════════════════════════════════════════════════════

var notes List<Note> = List<Note>.new([
    Note { id: 0, title: "Welcome", body: "This is your notes app. Click on any note to view it.", time: "Just now", pinned: true, tags: ["intro"], folder: "" },
    Note { id: 1, title: "Quick Ideas", body: "Build a markdown editor with live preview.", time: "10 min ago", pinned: false, tags: ["ideas"], folder: "" },
    Note { id: 2, title: "Shopping List", body: "Milk, Eggs, Bread, Cheese", time: "2 hours ago", pinned: false, tags: ["home"], folder: "personal" },
    Note { id: 3, title: "Recipe: Pasta", body: "200g flour, 2 eggs, pinch of salt.", time: "Last week", pinned: false, tags: ["home"], folder: "personal" },
    Note { id: 4, title: "Meeting Notes", body: "Q3 roadmap discussion.", time: "Yesterday", pinned: false, tags: ["work"], folder: "work" },
    Note { id: 5, title: "Sprint Planning", body: "Sprint 12 planning notes.", time: "3 days ago", pinned: false, tags: ["work"], folder: "work" },
])

var nextid int = 6

// ═══════════════════════════════════════════════════════════
// Folder storage
// ═══════════════════════════════════════════════════════════

var folders List<Folder> = List<Folder>.new([
    Folder { id: 0, name: "default", icon: "📄" },
    Folder { id: 1, name: "work", icon: "💼" },
    Folder { id: 2, name: "personal", icon: "🏠" },
    Folder { id: 3, name: "study", icon: "📚" },
])

var next_folder_id int = 4

// ═══════════════════════════════════════════════════════════
// Database Operations
// ═══════════════════════════════════════════════════════════

/// Find a note by ID
pub fn find_note(id int) ?Note {
    for note in notes {
        if note.id == id {
            return Some(note)
        }
    }
    return None
}

/// Get all notes (pinned first, then by id desc)
pub fn all_notes() []Note {
    return notes
}

/// Create a new note
pub fn create_note(title str, body str, folder str) Note {
    let note = Note {
        id: nextid,
        title: title,
        body: body,
        time: "Just now",
        pinned: false,
        tags: [],
        folder: folder,
    }
    nextid = nextid + 1
    notes.push(note)
    return note
}

/// Update an existing note
pub fn update_note(id int, title str, body str) ?Note {
    var new_notes List<Note> = List<Note>.new([])
    var found ?Note = None
    for note in notes {
        if note.id == id {
            let updated = Note {
                id: note.id,
                title: title,
                body: body,
                time: "Just now",
                pinned: note.pinned,
                tags: note.tags,
                folder: note.folder,
            }
            new_notes.push(updated)
            found = Some(updated)
        } else {
            new_notes.push(note)
        }
    }
    notes = new_notes
    return found
}

/// Delete a note by ID
pub fn delete_note(id int) bool {
    var new_notes List<Note> = List<Note>.new([])
    var found bool = false
    for note in notes {
        if note.id != id {
            new_notes.push(note)
        } else {
            found = true
        }
    }
    notes = new_notes
    return found
}

/// Toggle pin status
pub fn toggle_pin(id int) ?Note {
    var new_notes List<Note> = List<Note>.new([])
    var found ?Note = None
    for note in notes {
        if note.id == id {
            let updated = Note {
                id: note.id,
                title: note.title,
                body: note.body,
                time: note.time,
                pinned: !note.pinned,
                tags: note.tags,
                folder: note.folder,
            }
            new_notes.push(updated)
            found = Some(updated)
        } else {
            new_notes.push(note)
        }
    }
    notes = new_notes
    return found
}

/// Update tags for a note
pub fn update_tags(id int, tags []str) ?Note {
    var new_notes List<Note> = List<Note>.new([])
    var found ?Note = None
    for note in notes {
        if note.id == id {
            let updated = Note {
                id: note.id,
                title: note.title,
                body: note.body,
                time: note.time,
                pinned: note.pinned,
                tags: tags,
                folder: note.folder,
            }
            new_notes.push(updated)
            found = Some(updated)
        } else {
            new_notes.push(note)
        }
    }
    notes = new_notes
    return found
}

/// Search notes by title + body
pub fn search_notes(query str) []Note {
    let query_lower str = query.to_lower()
    let results List<Note> = List<Note>.new([])

    for note in notes {
        if note.title.to_lower().contains(query_lower) || note.body.to_lower().contains(query_lower) {
            results.push(note)
        }
    }

    return results
}

// ═══════════════════════════════════════════════════════════
// Folder Operations
// ═══════════════════════════════════════════════════════════

/// List all folders
pub fn all_folders() []Folder {
    return folders
}

/// Create a new folder
pub fn create_folder(name str) Folder {
    let folder = Folder {
        id: next_folder_id,
        name: name,
        icon: "📄",
    }
    next_folder_id = next_folder_id + 1
    folders.push(folder)
    return folder
}

/// List notes in a specific folder
pub fn notes_by_folder(folder str) []Note {
    let results List<Note> = List<Note>.new([])
    for note in notes {
        if note.folder == folder {
            results.push(note)
        }
    }
    return results
}

/// Move a note to a different folder
pub fn move_note(id int, folder str) ?Note {
    var new_notes List<Note> = List<Note>.new([])
    var found ?Note = None
    for note in notes {
        if note.id == id {
            let updated = Note {
                id: note.id,
                title: note.title,
                body: note.body,
                time: note.time,
                pinned: note.pinned,
                tags: note.tags,
                folder: folder,
            }
            new_notes.push(updated)
            found = Some(updated)
        } else {
            new_notes.push(note)
        }
    }
    notes = new_notes
    return found
}
