widget App {
    model {
        var name str = "Jane Cooper"
        var role str = "Full Stack Developer"
        var bio str = "Passionate about building great user experiences. Open source contributor and coffee enthusiast."
        var avatar_url str = "https://cn.cravatar.com/avatar/e1e7ba949ade0936e071132d2edd3b3c.png"
        var status str = "online"
    }

    view {
        center {
            // Card container
            col {
                // Header with gradient background
                col {
                    style: "h-20 bg-gradient-to-r from-blue-500 to-purple-600 rounded-t-lg"
                }

                // Avatar overlapping the header
                col {
                    image (src: .avatar_url) {
                        style: "w-20 h-20 rounded-full border-4 border-gray-200 shadow-md"
                    }
                    style: "-mt-10 items-center"
                }

                // Name and role
                col {
                    text .name
                    style: "text-xl font-bold text-gray-900"

                    row {
                        text .status
                        style: "w-3 h-3 rounded-full bg-green-400"
                        text "Active"
                        style: "text-sm text-gray-500"
                    }
                    style: "gap-2 items-center"
                }

                // Role badge
                row {
                    text .role
                    style: "px-3 py-1 bg-blue-100 text-blue-800 text-sm rounded-full font-medium"
                }

                // Bio
                text .bio {
                    style: "text-gray-600 text-sm text-center px-6 leading-relaxed"
                }

                // Action buttons
                row {
                    button "Follow" {
                        style: "px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600"
                    }
                    button "Message" {
                        style: "px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300"
                    }
                    style: "gap-3"
                }

                style: "bg-white rounded-lg shadow-lg border border-gray-200 max-w-sm mx-auto items-center gap-4 pb-6 overflow-hidden"
            }
        }
    }
}
