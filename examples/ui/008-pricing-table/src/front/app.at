                            }
                            span .feat4
                            style: "gap-2 items-center"
                        }
                        row {
                            span "✓" {
                                style: "text-blue-500 font-bold"
                            }
                            span .feat5
                            style: "gap-2 items-center"
                        }
                        style: "gap-3 mt-6"
                    }
                    button .plan1_btn {
                        style: "w-full py-2.5 bg-blue-500 text-white rounded-lg font-semibold mt-6"
                    }
                    style: "bg-white rounded-xl border-2 border-blue-500 p-6 flex-1"
                }

                // Team
                col {
                    col {
                        h3 .plan2_name {
                            style: "text-lg font-bold text-gray-900"
                        }
                        span .plan2_subtitle {
                            style: "text-sm text-gray-500"
                        }
