                            style: "text-sm text-gray-500"
                        }
                        span .plan1_price {
                            style: "text-4xl font-bold text-gray-900 mt-2"
                        }
                        style: "gap-1 items-center"
                    }
                    col {
                        row {
                            span "✓" {
                                style: "text-blue-500 font-bold"
                            }
                            span .plan1_devs
                            style: "gap-2 items-center"
                        }
                        row {
                            span "✓" {
                                style: "text-blue-500 font-bold"
                            }
                            span .feat1
                            style: "gap-2 items-center"
                        }
                        row {
                            span "✓" {
                                style: "text-blue-500 font-bold"
                            }
                            span .feat2
                            style: "gap-2 items-center"
                        }
                        row {
                            span "✓" {
                                style: "text-blue-500 font-bold"
                            }
                            span .feat3
