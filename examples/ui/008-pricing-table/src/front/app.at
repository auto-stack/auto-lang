widget App {
    model {
        // Single Developer
        var plan1_name str = "Single Developer"
        var plan1_subtitle str = "For individual developers"
        var plan1_price str = "$39"
        var plan1_devs str = "1 Developer"
        var plan1_btn str = "Buy Now"

        // Team
        var plan2_name str = "Team"
        var plan2_subtitle str = "For small teams"
        var plan2_price str = "$99"
        var plan2_devs str = "Up to 5 Developers"
        var plan2_btn str = "Buy Now"

        // Enterprise
        var plan3_name str = "Enterprise"
        var plan3_subtitle str = "For larger teams"
        var plan3_deal str = "Exclusive Deals"
        var plan3_devs str = "Unlimited Developers"
        var plan3_btn str = "Contact Us"

        // Shared features
        var feat1 str = "All Marketing + Application UI Blocks"
        var feat2 str = "Figma UI Kit"
        var feat3 str = "Lifetime Support"
        var feat4 str = "Unlimited Updates"
        var feat5 str = "Use on Unlimited Projects"
    }

