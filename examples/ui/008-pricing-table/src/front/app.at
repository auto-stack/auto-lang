                            style: "text-4xl font-bold text-gray-900 mt-2"
                        }
                        style: "gap-1 items-center"
                    }
                    col {
                        row {
                            span "✓" {
                                style: "text-gray-400 font-bold"
                            }
                            span .plan3_devs
                            style: "gap-2 items-center"
                        }
                        row {
                            span "✓" {
                                style: "text-gray-400 font-bold"
                            }
                            span .feat1
                            style: "gap-2 items-center"
                        }
                        row {
                            span "✓" {
                                style: "text-gray-400 font-bold"
                            }
                            span .feat2
                            style: "gap-2 items-center"
                        }
                        row {
                            span "✓" {
                                style: "text-gray-400 font-bold"
                            }
                            span .feat3
                            style: "gap-2 items-center"
                        }
                        row {
                            span "✓" {
                                style: "text-gray-400 font-bold"
                            }
                            span .feat4
                            style: "gap-2 items-center"
                        }
                        row {
                            span "✓" {
                                style: "text-gray-400 font-bold"
                            }
                            span .feat5
                            style: "gap-2 items-center"
                        }
                        style: "gap-3 mt-6"
                    }
                    button .plan3_btn {
                        style: "w-full py-2.5 bg-gray-500 text-white rounded-lg font-semibold mt-6"
