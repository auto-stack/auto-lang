                            }
                            span .feat1
                            style: "gap-2 items-center"
                        }
                        row {
                            span "✓" {
                                style: "text-orange-500 font-bold"
                            }
                            span .feat2
                            style: "gap-2 items-center"
                        }
                        row {
                            span "✓" {
                                style: "text-orange-500 font-bold"
                            }
                            span .feat3
                            style: "gap-2 items-center"
                        }
                        row {
                            span "✓" {
                                style: "text-orange-500 font-bold"
                            }
                            span .feat4
                            style: "gap-2 items-center"
                        }
                        row {
