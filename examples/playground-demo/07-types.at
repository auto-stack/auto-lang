// Type definitions and methods
type Point {
    x int
    y int

    static fn new(x int, y int) Point {
        return Point(x, y)
    }

    // `.x` reads a field of the receiver inside methods
    fn distance_squared() int {
        return .x * .x + .y * .y
    }
}

let p = Point.new(3, 4)
print(f"Point: (${p.x}, ${p.y})")
print(f"Distance squared: ${p.distance_squared()}")
