// widgets/TutorialItem.at - Tutorial list item

/// Tutorial item component with horizontal layout
widget TutorialItem {
    model {
        title str = ""
        brief str = ""
        imageSrc str = ""
    }

    view {
        row (style: "w-full p-3 bg-white rounded-2xl") {
            col (style: "flex-1 mr-3") {
                text (style: "text-sm", text: .title) {}
                text (style: "text-xs text-gray-600", text: .brief) {}
            }
            image (style: "h-16 w-28 rounded-2xl object-cover", src: .imageSrc) {}
        }
    }
}
