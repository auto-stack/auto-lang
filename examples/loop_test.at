// For loop and conditional test

widget LoopTest {
    msg Msg { Add }

    model {
        count int = 0
    }

    view {
        col {
            // For loop with loop variable
            for i in .items {
                text `Item ${i}`
            }

            // For loop with index
            for idx, name in .names {
                text `${idx}: ${name}`
            }

            // Conditional test with state
            if .count > 0 {
                text `Count: ${.count}`
            }
        }
    }

    on {
        Add -> {
            count = count + 1
        }
    }
}
