// Counter Widget - Full example with dot-prefix event handlers
widget Counter {
    msg Msg { Inc, Dec }

    model {
        count int = 0
    }

    view {
        col {} {
            > "Count: "
            row {} {
                button { text: "-", onclick: .Dec }
                button { text: "+", onclick: .Inc }
            }
        }
    }

    on {
        Inc => {
            count = count + 1
        }
        Dec => {
            count = count - 1
        }
    }
}
