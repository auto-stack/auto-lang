// pac.at - Unified Example Config
// Demonstrates unified AURA syntax for multiple backends

name: "UnifiedApp"
version: "1.0.0"
description: "Unified AURA Example - Works with Vue, Tauri, and Jet backends"

scene: "ui"

// Single backend for testing
backend: "jet"

// Workspace structure
workspace: {
    front: "./source/front"
}

// Source location
src: ["./source"]
