// 001-hello: Minimal proof that a2gd output runs in Godot
// Based on: Godot official "Step by Step" tutorial
// Tests: _ready(), print(), variables, basic arithmetic

fn main() {
    print("Hello from Auto!")
    print("This GDScript was generated by a2gd")
    let score = 100
    let lives = 3
    let total = score * lives
    print(total)
}
