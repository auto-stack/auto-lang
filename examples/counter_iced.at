// Counter Widget for Iced Backend Test
widget Counter {
    msg Msg { Inc, Dec }

    model {
        var count int = 0
    }

    view {
        col {
            text f"Count: ${.count}"
            row {
                button (text: "-", onclick: .Dec) {}
                button (text: "+", onclick: .Inc) {}
            }
        }
    }

    on {
        Inc -> {
            count = count + 1
        }
        Dec -> {
            count = count - 1
        }
    }
}
