// Canary K2/N4 — the child widget that receives a callback prop.
// (Uses a literal arg .Bump(1). A computed arg .Bump(.n+1) previously hit a
//  codegen OOM — now fixed by the binop-in-event-arg parser fix; see the
//  oom-event-binop-arg canary. A separate pre-existing issue: state-ref args
//  like .n render as `this.n` (wrong for Vue) — tracked separately.)

widget Counter(on_select: msg) {
    msg Msg { Bump(int) }
    model { var n int = 0 }
    view {
        col {
            button "increment" { onclick: .Bump(1) }
            text .n { }
            style: "gap-2"
        }
    }
    on {
        .Bump(next) -> {
            .n = next
            on_select(next)
        }
    }
}
