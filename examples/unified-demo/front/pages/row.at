// pages/row.at - Row demo page

/// Row demo page showcasing horizontal layout.

widget RowPage {
    view {
        Col {
            style: "p-4 gap-4"
            H2 "Row Demo"
            Text (variant: "muted") "Row arranges children horizontally."

            Row {
                style: "p-4 gap-4 bg-green-50 rounded-lg"
                Text "Left"
                Text "Center"
                Text "Right"
            }
        }
    }
}
