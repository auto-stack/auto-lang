// components/dialog.at - Dialog component

/// Dialog component for modal interactions.
///
/// # Features
/// - Modal overlay with backdrop
/// - Accessible with keyboard navigation
/// - Animated open/close transitions
///
/// # Usage
/// ```
/// dialog (open: .showDialog) {
///     dialog-trigger (text: "Open") {}
///     dialog-content {
///         dialog-header {
///             dialog-title (text: "Title") {}
///             dialog-description (text: "Description") {}
///         }
///     }
/// }
/// ```

widget Dialog {
    model {
        open bool = false
    }

    view {
        div { class: "dialog" }
    }
}

/// Dialog trigger button
widget DialogTrigger {
    msg Msg { Click }

    model {
        text str = "Open"
    }

    view {
        button { text: .text, onclick: .Click }
    }
}

/// Dialog content container
widget DialogContent {
    model {
        class str = ""
    }

    view {
        div { class: f"dialog-content ${.class}" }
    }
}

/// Dialog header section
widget DialogHeader {
    view {
        div { class: "flex flex-col space-y-1.5 text-center sm:text-left" }
    }
}

/// Dialog title
widget DialogTitle {
    model {
        text str = ""
    }

    view {
        h2 { class: "text-lg font-semibold leading-none tracking-tight", text: .text }
    }
}

/// Dialog description
widget DialogDescription {
    model {
        text str = ""
    }

    view {
        p { class: "text-sm text-muted-foreground", text: .text }
    }
}

/// Dialog footer section
widget DialogFooter {
    view {
        div { class: "flex flex-col-reverse sm:flex-row sm:justify-end sm:space-x-2" }
    }
}

/// Demo widget for Dialog documentation
widget DialogDemo {
    model {
        open bool = false
    }

    view {
        row (gap: "4") {
            dialog (open: .open) {
                dialog-trigger (text: "Open Dialog") {}
                dialog-content {
                    dialog-header {
                        dialog-title (text: "Edit Profile") {}
                        dialog-description (text: "Make changes to your profile here. Click save when you're done.") {}
                    }
                    dialog-footer {
                        button (text: "Save changes") {}
                    }
                }
            }
        }
    }
}
