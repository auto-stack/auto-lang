// components/datatable.at - DataTable component

/// DataTable component for advanced table features.
///
/// # Features
/// - Sorting by column (click header to toggle asc/desc)
/// - Filtering/searching across all columns
/// - Pagination with configurable page size
/// - Row selection with checkboxes
/// - Row actions menu

/// Basic DataTable - just the table, no features
widget DataTableBasic {
    model {}

    view {
        table {
            table-header {
                table-row {
                    table-head | Status
                    table-head | Email
                    table-head (text: "Amount", class: "text-right") {}
                }
            }
            table-body {
                table-row {
                    table-cell { badge (text: "Success", variant: "default") {} }
                    table-cell (text: "ken99@yahoo.com", class: "lowercase") {}
                    table-cell (text: "$316.00", class: "text-right font-medium") {}
                }
                table-row {
                    table-cell { badge (text: "Pending", variant: "secondary") {} }
                    table-cell (text: "abe45@gmail.com", class: "lowercase") {}
                    table-cell (text: "$242.00", class: "text-right font-medium") {}
                }
                table-row {
                    table-cell { badge (text: "Processing", variant: "outline") {} }
                    table-cell (text: "monserrat44@gmail.com", class: "lowercase") {}
                    table-cell (text: "$837.00", class: "text-right font-medium") {}
                }
                table-row {
                    table-cell { badge (text: "Failed", variant: "destructive") {} }
                    table-cell (text: "carmella@hotmail.com", class: "lowercase") {}
                    table-cell (text: "$721.00", class: "text-right font-medium") {}
                }
            }
        }
    }
}

/// DataTable with Sorting feature
widget DataTableSorting {
    msg Msg {
        ToggleSortStatus
        ToggleSortEmail
        ToggleSortAmount
    }

    model {
        sortColumn str = ""
        sortDirection str = "asc"
    }

    view {
        table {
            table-header {
                table-row {
                    table-head {
                        button (variant: "ghost", class: "-ml-4", onclick: .ToggleSortStatus) {
                            text | Status
                            icon (name: "arrow-up-down", class: "ml-2 h-4 w-4") {}
                        }
                    }
                    table-head {
                        button (variant: "ghost", class: "-ml-4", onclick: .ToggleSortEmail) {
                            text | Email
                            icon (name: "arrow-up-down", class: "ml-2 h-4 w-4") {}
                        }
                    }
                    table-head (class: "text-right") {
                        button (variant: "ghost", class: "-ml-4", onclick: .ToggleSortAmount) {
                            text | Amount
                            icon (name: "arrow-up", class: "ml-2 h-4 w-4") {}
                        }
                    }
                }
            }
            table-body {
                table-row {
                    table-cell { badge (text: "Success", variant: "default") {} }
                    table-cell (text: "abe45@gmail.com", class: "lowercase") {}
                    table-cell (text: "$242.00", class: "text-right font-medium") {}
                }
                table-row {
                    table-cell { badge (text: "Failed", variant: "destructive") {} }
                    table-cell (text: "carmella@hotmail.com", class: "lowercase") {}
                    table-cell (text: "$721.00", class: "text-right font-medium") {}
                }
                table-row {
                    table-cell { badge (text: "Success", variant: "default") {} }
                    table-cell (text: "ken99@yahoo.com", class: "lowercase") {}
                    table-cell (text: "$316.00", class: "text-right font-medium") {}
                }
                table-row {
                    table-cell { badge (text: "Processing", variant: "outline") {} }
                    table-cell (text: "monserrat44@gmail.com", class: "lowercase") {}
                    table-cell (text: "$837.00", class: "text-right font-medium") {}
                }
            }
        }
    }
}

