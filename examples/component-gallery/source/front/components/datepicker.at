// components/datepicker.at - DatePicker component

/// DatePicker component for date selection.
///
/// # Features
/// - Date selection with calendar
/// - Date range selection
/// - Formatted display
/// - Accessible with keyboard
///
/// # Usage
/// ```
/// date-picker (selected: .date, onchange: .SelectDate) {
///     date-picker-trigger {
///         input (placeholder: "Select date") {}
///     }
///     date-picker-content {
///         calendar {}
///     }
/// }
/// ```

widget DatePicker {
    msg Msg {
        Select(date: str)
        Clear
    }

    model {
        selected str = ""
        placeholder str = "Pick a date"
        disabled bool = false
        open bool = false
    }

    computed {
        displayValue => if .selected != "" {
            .selected
        } else {
            .placeholder
        }
    }

    view {
        Popover (open: .open) {
            popover-trigger {
                DatePickerTrigger (value: .displayValue) {}
            }
            popover-content (class: "w-auto p-0") {
                Calendar (selected: .selected) {}
            }
        }
    }
}

/// DatePicker trigger button
widget DatePickerTrigger {
    model {
        value str = ""
    }

    view {
        button { class: "date-picker-trigger" } {
            text (text: .value) {}
            text (text: "📅", class: "ml-2") {}
        }
    }
}

/// DatePicker content wrapper
widget DatePickerContent {
    view {
        div { class: "date-picker-content" }
    }
}

/// DateRangePicker for selecting date ranges
widget DateRangePicker {
    model {
        start str = ""
        end str = ""
    }

    view {
        Popover {
            popover-trigger {
                row (gap: "2") {
                    DatePickerTrigger (value: if .start != "" { .start } else { "Start date" }) {}
                    text | -
                    DatePickerTrigger (value: if .end != "" { .end } else { "End date" }) {}
                }
            }
            popover-content (class: "w-auto p-0") {
                // Would contain range calendar
                div { class: "p-4" }
            }
        }
    }
}

/// Demo widget for DatePicker documentation
widget DatePickerDemo {
    model {
        selectedDate str = ""
    }

    view {
        col (gap: "4") {
            DatePicker (selected: .selectedDate) {
                date-picker-trigger {
                    input (placeholder: "Select a date") {}
                }
            }
            text (text: f"Selected: ${.selectedDate}") {}
        }
    }
}
