                            link (to: "/switch") {
                                text (text: "Switch", style: "block px-3 py-0 rounded-md hover:bg-muted cursor-pointer text-sm") {}
                            }
                            link (to: "/table") {
                                text (text: "Table", style: "block px-3 py-0 rounded-md hover:bg-muted cursor-pointer text-sm") {}
                            }
                            link (to: "/tabs") {
                                text (text: "Tabs", style: "block px-3 py-0 rounded-md hover:bg-muted cursor-pointer text-sm") {}
                            }
                            link (to: "/textarea") {
                                text (text: "Textarea", style: "block px-3 py-0 rounded-md hover:bg-muted cursor-pointer text-sm") {}
                            }
                            link (to: "/toast") {
                                text (text: "Toast", style: "block px-3 py-0 rounded-md hover:bg-muted cursor-pointer text-sm") {}
                            }
                            link (to: "/toggle") {
                                text (text: "Toggle", style: "block px-3 py-0 rounded-md hover:bg-muted cursor-pointer text-sm") {}
                            }
                            link (to: "/togglegroup") {
                                text (text: "ToggleGroup", style: "block px-3 py-0 rounded-md hover:bg-muted cursor-pointer text-sm") {}
                            }
                            link (to: "/tooltip") {
                                text (text: "Tooltip", style: "block px-3 py-0 rounded-md hover:bg-muted cursor-pointer text-sm") {}
                            }
                        }
                    }
                }

                // Route outlet - renders the matched page component
                main (style: "flex-1 p-8 h-[calc(100vh-3.5rem)] overflow-hidden") {
                    scroll (style: "h-full pr-4") {
                        outlet
                    }
                }
            }
        }
    }
