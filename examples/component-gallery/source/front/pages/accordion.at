// pages/accordion.at - Accordion component documentation page

widget AccordionPage {
    model { activeTab str = "preview" }

    view {
        col {
            h1 "Accordion"
            text "A vertically stacked set of interactive headings that each reveal a section of content."

            h2 "Installation"
            codeblock (lang: "bash", code: "npx shadcn-vue@latest add accordion") {}

            h2 "Simple"
            preview-card (id: "accordion-basic") {
                accordion (type: "single", collapsible: "true", class: "w-full") {
                    accordion-item (value: "item-1") {
                        accordion-trigger "Is it accessible?"
                        accordion-content {
                            text "Yes. It adheres to the WAI-ARIA design pattern."
                        }
                    }
                    accordion-item (value: "item-2") {
                        accordion-trigger "Is it styled?"
                        accordion-content {
                            text "Yes. It comes with default styles that match the other components."
                        }
                    }
                    accordion-item (value: "item-3") {
                        accordion-trigger "Is it animated?"
                        accordion-content {
                            text "Yes. It's animated by default, but you can disable it if you prefer."
                        }
                    }
                }
            }

            h2 "Properties"
            table {
                thead {
                    tr {
                        th "Property"
                        th "Type"
                        th "Default"
                        th "Values"
                        th "Description"
                    }
                }
                tbody {
                    tr {
                        td "type"
                        td "string"
                        td "single"
                        td "single, multiple"
                        td "Single or multiple items open"
                    }
                    tr {
                        td "collapsible"
                        td "boolean"
                        td "false"
                        td "true, false"
                        td "Allow all items to be collapsed"
                    }
                }
            }
        }
    }
}
