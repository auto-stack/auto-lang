// pages/collapsible.at - Collapsible component documentation page

widget CollapsiblePage {
    model {
        activeTab str = "preview"
        isOpen bool = false
    }

    view {
        col {
            h1 "Collapsible"
            text "An interactive component which expands or collapses a content panel."

            h2 "Installation"
            codeblock (lang: "bash", code: "npx shadcn-vue@latest add collapsible") {}

            h2 "Example"
            preview-card (id: "collapsible-basic") {
                collapsible (open: .isOpen) {
                    collapsible-trigger (style: "flex items-center justify-between w-full py-4 font-medium [&[data-state=open]>span:last-child]:rotate-180") {
                        text "Can I use this in my project?"
                        text (text: "▸", style: "transition-transform duration-200") {}
                    }
                    collapsible-content (style: "pb-4") {
                        text "Yes. Free to use for personal and commercial projects. No attribution required."
                    }
                }
            }

            h2 "Properties"
            table {
                thead {
                    tr {
                        th "Property"
                        th "Type"
                        th "Default"
                        th "Values"
                        th "Description"
                    }
                }
                tbody {
                    tr {
                        td "open"
                        td "boolean"
                        td "false"
                        td "true, false"
                        td "Controls open state"
                    }
                    tr {
                        td "disabled"
                        td "boolean"
                        td "false"
                        td "true, false"
                        td "Disables the collapsible"
                    }
                    tr {
                        td "class"
                        td "string"
                        td "-"
                        td "-"
                        td "Additional CSS classes"
                    }
                }
            }
        }
    }
}
