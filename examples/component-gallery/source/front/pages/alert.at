// pages/alert.at - Alert component documentation page

widget AlertPage {
    model { activeTab str = "preview" }

    view {
        col {
            h1 | Alert
            text | Displays a callout for user attention.

            h2 | Installation
            codeblock (lang: "bash", code: "npx shadcn-vue@latest add alert") {}

            h2 | Simple
            preview-card (id: "alert-basic") {
                alert {
                    text | This is an alert message.
                }
            }

            h2 | Variants
            preview-card (id: "alert-variants") {
                col (gap: "4") {
                    alert (variant: "default") {
                        text | Default alert
                    }
                    alert (variant: "destructive") {
                        text | Error alert
                    }
                }
            }

            h2 | Properties
            table {
                thead {
                    tr {
                        th | Property
                        th | Type
                        th | Default
                        th | Values
                        th | Description
                    }
                }
                tbody {
                    tr {
                        td | variant
                        td | string
                        td | default
                        td | default, destructive
                        td | Alert style variant
                    }
                }
            }
        }
    }
}
