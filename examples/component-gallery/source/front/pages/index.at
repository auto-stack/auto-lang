                        }
                    }
                    link (to: "/input") {
                        div (style: "border rounded-lg p-4 hover:bg-muted transition-colors") {
                            text "Input"
                        }
                    }
                    link (to: "/label") {
                        div (style: "border rounded-lg p-4 hover:bg-muted transition-colors") {
                            text "Label"
                        }
                    }
                    // Row 7
                    link (to: "/menubar") {
                        div (style: "border rounded-lg p-4 hover:bg-muted transition-colors") {
                            text "Menubar"
                        }
