                            text "NavigationMenu"
                        }
                    }
                    link (to: "/pagination") {
                        div (style: "border rounded-lg p-4 hover:bg-muted transition-colors") {
                            text "Pagination"
                        }
                    }
                    link (to: "/popover") {
                        div (style: "border rounded-lg p-4 hover:bg-muted transition-colors") {
                            text "Popover"
                        }
                    }
                    // Row 8
                    link (to: "/progress") {
                        div (style: "border rounded-lg p-4 hover:bg-muted transition-colors") {
                            text "Progress"
                        }
                    }
                    link (to: "/radiogroup") {
                        div (style: "border rounded-lg p-4 hover:bg-muted transition-colors") {
                            text "RadioGroup"
                        }
                    }
                    link (to: "/scrollarea") {
                        div (style: "border rounded-lg p-4 hover:bg-muted transition-colors") {
                            text "ScrollArea"
                        }
                    }
                    link (to: "/select") {
                        div (style: "border rounded-lg p-4 hover:bg-muted transition-colors") {
                            text "Select"
                        }
                    }
                    // Row 9
                    link (to: "/separator") {
                        div (style: "border rounded-lg p-4 hover:bg-muted transition-colors") {
                            text "Separator"
                        }
                    }
                    link (to: "/sheet") {
                        div (style: "border rounded-lg p-4 hover:bg-muted transition-colors") {
                            text "Sheet"
                        }
                    }
                    link (to: "/sidebar") {
                        div (style: "border rounded-lg p-4 hover:bg-muted transition-colors") {
                            text "Sidebar"
                        }
                    }
                    link (to: "/skeleton") {
                        div (style: "border rounded-lg p-4 hover:bg-muted transition-colors") {
                            text "Skeleton"
                        }
                    }
                    // Row 10
                    link (to: "/slider") {
                        div (style: "border rounded-lg p-4 hover:bg-muted transition-colors") {
                            text "Slider"
                        }
                    }
                    link (to: "/sonner") {
                        div (style: "border rounded-lg p-4 hover:bg-muted transition-colors") {
                            text "Sonner"
                        }
                    }
                    link (to: "/switch") {
                        div (style: "border rounded-lg p-4 hover:bg-muted transition-colors") {
