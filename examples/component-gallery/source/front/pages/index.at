                        }
                    }
                    link (to: "/toast") {
                        div (style: "border rounded-lg p-4 hover:bg-muted transition-colors") {
                            text "Toast"
                        }
                    }
                    link (to: "/toggle") {
                        div (style: "border rounded-lg p-4 hover:bg-muted transition-colors") {
                            text "Toggle"
                        }
                    }
                    // Row 12
                    link (to: "/togglegroup") {
                        div (style: "border rounded-lg p-4 hover:bg-muted transition-colors") {
                            text "ToggleGroup"
