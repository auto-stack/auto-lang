                        }
                    }
                    link (to: "/table") {
                        div (style: "border rounded-lg p-4 hover:bg-muted transition-colors") {
                            text "Table"
                        }
                    }
                    // Row 11
                    link (to: "/tabs") {
                        div (style: "border rounded-lg p-4 hover:bg-muted transition-colors") {
                            text "Tabs"
                        }
                    }
                    link (to: "/textarea") {
                        div (style: "border rounded-lg p-4 hover:bg-muted transition-colors") {
