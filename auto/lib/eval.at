// Tree-Walking Evaluator for the Auto self-hosted compiler
// Evaluates structured AST nodes directly using heap object traversal

// Evaluator environment
type EvalEnv {
    globals Map       // global variable bindings: name -> value
    scopes List       // scope stack: List of Map
    fn_defs Map       // function definitions: name -> ASTNode (heap id)
    output str        // accumulated print output
}

// Create a new evaluator environment
fn eval_new() EvalEnv {
    EvalEnv(Map.new(), List.new(), Map.new(), "")
}

// ---- Side Channel ----
// Use globals Map to store string values and type tags
// Key "__last_str__"  → last evaluated string (stored via insert_str)
// Key "__last_type__" → 0=int, 1=str, 2=bool (stored as int)

fn eval_set_last_str(env EvalEnv, s str) {
    env.globals.insert_str("__last_str__", s)
}

fn eval_get_last_str(env EvalEnv) str {
    if env.globals.contains("__last_str__") {
        return env.globals.get("__last_str__")
    }
    return ""
}

fn eval_set_last_type(env EvalEnv, t int) {
    env.globals.insert_int("__last_type__", t)
}

fn eval_get_last_type(env EvalEnv) int {
    if env.globals.contains("__last_type__") {
        return env.globals.get_int("__last_type__")
    }
    return 0
}

// ---- Variable Type Tracking ----
// Store str variables with "__s__" prefix, int variables without prefix
// This avoids needing a separate var_types Map

fn eval_str_key(name str) str {
    return "__s__" + name
}

fn eval_is_str_var(env EvalEnv, name str) int {
    var skey = eval_str_key(name)
    if env.globals.contains(skey) {
        return 1
    }
    return 0
}

// ---- Scope Management ----
// NOTE: scope maps are kept for future use, but all variable
// operations go through globals to avoid type inference issues
// with "var scope = env.scopes.get(...)" pattern.

fn eval_push_scope(env EvalEnv) {
    env.scopes.push(Map.new())
}

fn eval_pop_scope(env EvalEnv) {
    if env.scopes.len() > 0 {
        var scope = env.scopes.pop()
        scope.drop()
    }
}

// Bind a variable in the current scope (int value)
fn eval_bind(env EvalEnv, name str, value) {
    env.globals.insert_int(name, value)
}

// Bind int variable
fn eval_bind_int(env EvalEnv, name str, value int) {
    env.globals.insert_int(name, value)
}

// Bind string variable — stores with __s__ prefix
fn eval_bind_str(env EvalEnv, name str, value str) {
    var skey = eval_str_key(name)
    env.globals.insert_str(skey, value)
}

// Look up a variable by name — returns int value
fn eval_lookup_int(env EvalEnv, name str) int {
    if env.globals.contains(name) {
        return env.globals.get_int(name)
    }
    return 0
}

// Look up a string variable by name (using __s__ prefix)
fn eval_lookup_str_var(env EvalEnv, name str) str {
    var skey = eval_str_key(name)
    if env.globals.contains(skey) {
        return env.globals.get(skey)
    }
    return ""
}

// Look up a variable by name — returns str value
fn eval_lookup_str(env EvalEnv, name str) str {
    if env.globals.contains(name) {
        return env.globals.get(name)
    }
    return ""
}

// ---- String Concat Helper ----
// Needed because AutoVM may not detect the type of ASTNode fields
// so the compiler won't emit STR_CAT for `left_node.name + right_node.name`.
// This function forces str-typed args so the compiler emits STR_CAT.

fn eval_str_cat(a str, b str) str {
    return a + b
}

// ---- String to Int Conversion ----

fn str_to_int(s str) int {
    var result = 0
    var neg = 0
    var i = 0
    var n = s.len()
    if n == 0 {
        return 0
    }
    var ch = s.char_at(0)
    if ch == 45 {
        neg = 1
        i = 1
    }
    for i < n {
        ch = s.char_at(i)
        if ch >= 48 && ch <= 57 {
            result = result * 10 + (ch - 48)
        } else {
            break
        }
        i = i + 1
    }
    if neg == 1 {
        result = 0 - result
    }
    return result
}

// ---- Int to String Conversion ----

fn int_to_str(n int) str {
    if n == 0 {
        return "0"
    }
    var neg = 0
    if n < 0 {
        neg = 1
        n = 0 - n
    }
    var digits = "0123456789"
    var result = ""
    for n > 0 {
        var d = n % 10
        result = digits.substr(d, d + 1) + result
        n = n / 10
    }
    if neg == 1 {
        result = "-" + result
    }
    return result
}

// ---- String Part Extraction ----
// Get the N-th part of a comma-separated string (e.g., "x,y,z" part 0 = "x")
// Used to extract param names from fn_def.op without needing DotExpr on Param objects

fn str_get_part(s str, index int) str {
    var start = 0
    var part = 0
    var i = 0
    var n = s.len()
    for i <= n {
        var ch = 0
        if i < n {
            ch = s.char_at(i)
        }
        if ch == 44 || i == n {
            if part == index {
                return s.substr(start, i)
            }
            part = part + 1
            start = i + 1
        }
        i = i + 1
    }
    return ""
}

// ---- Entry Points ----

// Evaluate a full program (list of top-level statements)
fn eval_program(env EvalEnv, stmts List) {
    // First pass: register all function definitions
    var i = 0
    var n = stmts.len()
    for i < n {
        var stmt = stmts.get(i)
        if stmt.kind == NodeKind.FnStmt {
            env.fn_defs.insert_int(stmt.name, stmt)
        }
        i = i + 1
    }

    // Second pass: execute all statements
    i = 0
    for i < n {
        var stmt = stmts.get(i)
        eval_exec_stmt(env, stmt)
        i = i + 1
    }
}

// Run evaluator on source code string
fn run_eval(source str) str {
    var tokens = tokenize_list(source)
    var p = parser_new(tokens)
    var stmts = parse_program(p)
    var env = eval_new()
    eval_program(env, stmts)
    return env.output
}

// ---- Statement Execution ----

// Execute a statement, returns 1 if return was hit
fn eval_exec_stmt(env EvalEnv, node ASTNode) int {
    var kind = node.kind

    if kind == NodeKind.FnStmt {
        env.fn_defs.insert_int(node.name, node)
        return 0
    }

    if kind == NodeKind.LetStmt || kind == NodeKind.VarStmt {
        var expr = node.left.get(0)
        var val = eval_expr(env, expr)
        if eval_get_last_type(env) == 1 {
            eval_bind_str(env, node.name, eval_get_last_str(env))
        } else {
            eval_bind_int(env, node.name, val)
        }
        return 0
    }

    if kind == NodeKind.ReturnStmt {
        return 1
    }

    if kind == NodeKind.IfStmt {
        return eval_if(env, node)
    }

    if kind == NodeKind.ForStmt {
        return eval_for(env, node)
    }

    if kind == NodeKind.ForInStmt {
        return eval_forin(env, node)
    }

    if kind == NodeKind.ExprStmt {
        var val = eval_expr(env, node.left.get(0))
        // Store for implicit return in eval_exec_body
        env.globals.insert_int("__last_expr__", val)
        return 0
    }

    if kind == NodeKind.BlockStmt {
        return eval_block(env, node)
    }

    return 0
}

// Execute a list of statements (body), returns 1 if return was hit
// Sets return_value in env.globals under key "__ret__"
fn eval_exec_body(env EvalEnv, body List) int {
    var i = 0
    var n = body.len()
    for i < n {
        var stmt = body.get(i)
        if stmt.kind == NodeKind.ReturnStmt {
            var val = 0
            if stmt.left.len() > 0 {
                val = eval_expr(env, stmt.left.get(0))
            }
            env.globals.insert_int("__ret__", val)
            env.globals.insert_int("__ret_type__", eval_get_last_type(env))
            if eval_get_last_type(env) == 1 {
                env.globals.insert_str("__ret_str__", eval_get_last_str(env))
            }
            return 1
        }
        var ret = eval_exec_stmt(env, stmt)
        if ret == 1 {
            return 1
        }
        // Implicit return: last ExprStmt (reuse eval state from eval_exec_stmt)
        // Do NOT re-evaluate — that would double-fire side effects like print()
        if i == n - 1 {
            if stmt.kind == NodeKind.ExprStmt {
                // eval_exec_stmt already called eval_expr, which set last_type/last_str
                // Just store the value from the last_expr_value side channel
                if env.globals.contains("__last_expr__") {
                    env.globals.insert_int("__ret__", env.globals.get_int("__last_expr__"))
                }
                if env.globals.contains("__last_type__") {
                    env.globals.insert_int("__ret_type__", env.globals.get_int("__last_type__"))
                }
                if env.globals.contains("__last_str__") {
                    env.globals.insert_str("__ret_str__", env.globals.get("__last_str__"))
                }
            }
        }
        i = i + 1
    }
    return 0
}

// ---- Expression Evaluation ----

// Evaluate an expression and return its int value
fn eval_expr(env EvalEnv, node ASTNode) int {
    var kind = node.kind

    if kind == NodeKind.IntExpr {
        eval_set_last_type(env, 0)
        return str_to_int(node.name)
    }

    if kind == NodeKind.StrExpr {
        eval_set_last_str(env, node.name)
        eval_set_last_type(env, 1)
        return 0
    }

    if kind == NodeKind.BoolExpr {
        if node.name == "true" {
            eval_set_last_type(env, 2)
            return 1
        }
        eval_set_last_type(env, 2)
        return 0
    }

    if kind == NodeKind.IdentExpr {
        if eval_is_str_var(env, node.name) == 1 {
            eval_set_last_str(env, eval_lookup_str_var(env, node.name))
            eval_set_last_type(env, 1)
            return 0
        }
        eval_set_last_type(env, 0)
        return eval_lookup_int(env, node.name)
    }

    if kind == NodeKind.BinExpr {
        return eval_binop(env, node)
    }

    if kind == NodeKind.UnaryExpr {
        return eval_unary(env, node)
    }

    if kind == NodeKind.CallExpr {
        return eval_call(env, node)
    }

    if kind == NodeKind.DotExpr {
        return eval_dot(env, node)
    }

    if kind == NodeKind.FStrExpr {
        return 0
    }

    if kind == NodeKind.NilNode {
        return 0
    }

    return 0
}

// ---- Binary Operations ----

fn eval_binop(env EvalEnv, node ASTNode) int {
    var op = node.op

    // String concatenation: "a" + "b"
    if op == "+" {
        var left_node = node.left.get(0)
        var right_node = node.right.get(0)
        // Both sides are string literals
        if left_node.kind == NodeKind.StrExpr && right_node.kind == NodeKind.StrExpr {
            eval_set_last_str(env, eval_str_cat(left_node.name, right_node.name))
            eval_set_last_type(env, 1)
            return 0
        }
        // Left is string literal, right needs eval
        if left_node.kind == NodeKind.StrExpr {
            var right_val = eval_expr(env, right_node)
            if eval_get_last_type(env) == 1 {
                eval_set_last_str(env, eval_str_cat(left_node.name, eval_get_last_str(env)))
            } else {
                eval_set_last_str(env, eval_str_cat(left_node.name, int_to_str(right_val)))
            }
            eval_set_last_type(env, 1)
            return 0
        }
        // Left is str variable
        if left_node.kind == NodeKind.IdentExpr {
            if eval_is_str_var(env, left_node.name) == 1 {
                var left_str = eval_lookup_str_var(env, left_node.name)
                var right_val = eval_expr(env, right_node)
                if eval_get_last_type(env) == 1 {
                    eval_set_last_str(env, eval_str_cat(left_str, eval_get_last_str(env)))
                } else {
                    eval_set_last_str(env, eval_str_cat(left_str, int_to_str(right_val)))
                }
                eval_set_last_type(env, 1)
                return 0
            }
        }
        var left = eval_expr(env, left_node)
        var right = eval_expr(env, right_node)
        return left + right
    }

    var left = eval_expr(env, node.left.get(0))
    var right = eval_expr(env, node.right.get(0))

    if op == "-" { return left - right }
    if op == "*" { return left * right }
    if op == "/" { return left / right }
    if op == "%" { return left % right }

    if op == "==" { return left == right }
    if op == "!=" { return left != right }
    if op == "<" { return left < right }
    if op == ">" { return left > right }
    if op == "<=" { return left <= right }
    if op == ">=" { return left >= right }

    if op == "||" {
        if left != 0 { return 1 }
        if right != 0 { return 1 }
        return 0
    }
    if op == "&&" {
        if left == 0 { return 0 }
        if right == 0 { return 0 }
        return 1
    }

    if op == ".." { return left }
    if op == "..=" { return left }

    if op == "=" {
        // Assignment: bind right value to left's name
        var left_node = node.left.get(0)
        if eval_get_last_type(env) == 1 {
            eval_bind_str(env, left_node.name, eval_get_last_str(env))
        } else {
            eval_bind_int(env, left_node.name, right)
        }
        return right
    }

    return 0
}

// ---- Unary Operations ----

fn eval_unary(env EvalEnv, node ASTNode) int {
    var op = node.op
    var operand = eval_expr(env, node.left.get(0))

    if op == "-" { return 0 - operand }
    if op == "!" {
        if operand == 0 { return 1 }
        return 0
    }

    return operand
}

// ---- Function Calls ----

fn eval_call(env EvalEnv, node ASTNode) int {
    var callee_name = node.name

    // Built-in: print — evaluate arg and append to output
    if callee_name == "print" {
        if node.params.len() == 0 {
            env.output = eval_str_cat(env.output, "\n")
            return 0
        }
        // Check arg type for proper formatting
        var arg_node = node.params.get(0)
        if arg_node.kind == NodeKind.BoolExpr {
            if arg_node.name == "true" {
                env.output = eval_str_cat(env.output, "true\n")
            } else {
                env.output = eval_str_cat(env.output, "false\n")
            }
            return 0
        }
        if arg_node.kind == NodeKind.StrExpr {
            env.output = eval_str_cat(env.output, eval_str_cat(arg_node.name, "\n"))
            return 0
        }
        // Evaluate the arg expression
        var result = eval_expr(env, arg_node)
        if eval_get_last_type(env) == 1 {
            env.output = eval_str_cat(env.output, eval_str_cat(eval_get_last_str(env), "\n"))
        } else {
            env.output = eval_str_cat(env.output, eval_str_cat(int_to_str(result), "\n"))
        }
        return result
    }

    // Built-in: empty_list / List.new
    if callee_name == "empty_list" {
        return 0
    }

    // Built-in: str_to_int
    if callee_name == "str_to_int" {
        return 0
    }

    // User-defined function
    if env.fn_defs.contains(callee_name) {
        return eval_fn_call(env, node, callee_name)
    }

    return 0
}

// Call a user-defined function
fn eval_fn_call(env EvalEnv, call_node ASTNode, fn_name str) int {
    var fn_def = env.fn_defs.get(fn_name)

    var params = fn_def.params
    var params_count = params.len()
    // Param names stored as pipe-separated string in fn_def.op
    // (set by parse_fn_decl to avoid DotExpr on Param objects)
    var param_names = fn_def.op

    // Push new scope
    eval_push_scope(env)

    // Evaluate each arg and bind to param
    var i = 0
    for i < params_count {
        if i < call_node.params.len() {
            var arg_val = eval_expr(env, call_node.params.get(i))
            var lt = eval_get_last_type(env)
            // Get param name from pipe-separated string
            var pname = str_get_part(param_names, i)
            if lt == 1 {
                eval_bind_str(env, pname, eval_get_last_str(env))
            } else {
                eval_bind_int(env, pname, arg_val)
            }
        }
        i = i + 1
    }

    // Execute function body
    var body = fn_def.children
    eval_exec_body(env, body)

    // Get return value
    var result = 0
    if env.globals.contains("__ret_type__") {
        var ret_type = env.globals.get_int("__ret_type__")
        if ret_type == 1 && env.globals.contains("__ret_str__") {
            eval_set_last_str(env, env.globals.get("__ret_str__"))
            eval_set_last_type(env, 1)
        }
    }
    if env.globals.contains("__ret__") {
        result = env.globals.get_int("__ret__")
    }

    eval_pop_scope(env)
    return result
}

// ---- Dot Access ----

fn eval_dot(env EvalEnv, node ASTNode) int {
    var obj = eval_expr(env, node.left.get(0))
    var field = node.name

    // List/string .len()
    if field == "len" {
        return obj
    }

    return 0
}

// ---- Control Flow ----

fn eval_if(env EvalEnv, node ASTNode) int {
    var cond = eval_expr(env, node.cond.get(0))
    if cond != 0 {
        return eval_exec_body(env, node.children)
    } else {
        if node.else_body.len() > 0 {
            var first = node.else_body.get(0)
            if first.kind == NodeKind.IfStmt {
                return eval_if(env, first)
            }
            return eval_exec_body(env, node.else_body)
        }
    }
    return 0
}

fn eval_for(env EvalEnv, node ASTNode) int {
    var cond_node = node.left.get(0)
    var body = node.children
    var limit = 10000
    var count = 0
    for true {
        var cond = eval_expr(env, cond_node)
        if cond == 0 { break }
        var ret = eval_exec_body(env, body)
        if ret == 1 { return 1 }
        count = count + 1
        if count >= limit { break }
    }
    return 0
}

fn eval_forin(env EvalEnv, node ASTNode) int {
    var range_node = node.left.get(0)
    var body = node.children
    var var_name = node.name

    var start_val = eval_expr(env, range_node.left.get(0))
    var end_val = eval_expr(env, range_node.right.get(0))
    var inclusive = 0
    if range_node.op == "..=" {
        inclusive = 1
    }

    var i = start_val
    var limit = end_val
    if inclusive == 1 {
        limit = end_val + 1
    }
    for i < limit {
        eval_bind(env, var_name, i)
        var ret = eval_exec_body(env, body)
        if ret == 1 { return 1 }
        i = i + 1
    }
    return 0
}

fn eval_block(env EvalEnv, node ASTNode) int {
    return eval_exec_body(env, node.children)
}

// ---- Bytecode Compilation + Execution Entry Point ----

fn run_bytecode(source str) str {
    var tokens = tokenize_list(source)
    var p = parser_new(tokens)
    var stmts = parse_program(p)
    // Type inference
    var tenv = typeenv_new()
    type_infer_program(tenv, stmts)
    // Compile to bytecode
    var cg = codegen_new()
    codegen_compile(cg, stmts, tenv)
    // Execute bytecode
    var state = Map.new()
    bvm_init(state)
    state.insert_int("__nstr", cg.n_strings)
    return bvm_run(cg.code, cg.strings, state)
}
