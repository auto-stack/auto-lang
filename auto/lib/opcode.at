// AutoVM Bytecode Opcodes — AAVM self-hosted compiler
// Constants aligned with Rust VM opcode.rs
// NOTE: Using inline values because top-level let is not accessible inside functions

// Stack
let OP_POP = 1
let OP_DUP = 3
let OP_RESERVE_STACK = 6

// Constants
let OP_CONST_I32 = 16
let OP_CONST_0 = 18
let OP_CONST_1 = 19
let OP_LOAD_STR = 31

// Locals
let OP_LOAD_LOCAL = 32
let OP_STORE_LOCAL = 33

// Arithmetic
let OP_ADD = 48
let OP_SUB = 49
let OP_MUL = 50
let OP_DIV = 51
let OP_MOD = 52

// Comparison
let OP_EQ = 80
let OP_NE = 81
let OP_LT = 82
let OP_GT = 83
let OP_LE = 84
let OP_GE = 85

// Control
let OP_JMP = 96
let OP_JMP_IF_Z = 97

// Functions
let OP_CALL = 112
let OP_RET = 113
let OP_CALL_NAT = 114

// String
let OP_STR_CAT = 124

// Halt
let OP_HALT = 255

// Boolean sentinels (use i32 min/max)
let BOOL_TRUE = -2147483648
let BOOL_FALSE = -2147483647

// Native function IDs
let NATIVE_PRINT_I32 = 1
let NATIVE_PRINT_STR = 3
