// Reverse-translated from godot-demo-projects/2d/hexagonal_map/{troll.gd,troll.tscn} (Plan 308).
// A CharacterBody2D "Troll" with hex-grid-aware movement.
//
// Translation notes (round-trip divergences from the original):
//  - `&"move_left"` StringName -> plain "move_left" (no & literal in Auto).
//  - `motion.y *= X` -> `motion.y = motion.y * X` (explicit field reassignment).
scene Troll : CharacterBody2D {
    script = "troll.gd"

    node Sprite2D {
        texture = load("res://troll.png")
    }

    node Sprite2D "Shadow" {
        modulate = Color(0, 0, 0, 0.501961)
        show_behind_parent = true
        position = Vector2(16.4422, 4.89438)
        scale = Vector2(0.794259, 1.04505)
        skew = 0.523599
        texture = load("res://troll.png")
    }

    node CollisionShape2D {
        position = Vector2(3.24216, 19.453)
        shape = CircleShape2D {
            radius = 16.0
        }
    }

    node Camera2D {
        process_callback = 0
    }
}

const MOTION_SPEED = 30
const FRICTION_FACTOR = 0.89
const TAN30DEG = tan(deg_to_rad(30))

fn _physics_process(delta f64) {
    var motion = Vector2()
    motion.x = Input.get_axis("move_left", "move_right")
    motion.y = Input.get_axis("move_up", "move_down")
    // Make diagonal movement fit for hexagonal tiles.
    motion.y = motion.y * TAN30DEG
    velocity = velocity + motion.normalized() * MOTION_SPEED
    // Apply friction.
    velocity = velocity * FRICTION_FACTOR
    move_and_slide()
}
