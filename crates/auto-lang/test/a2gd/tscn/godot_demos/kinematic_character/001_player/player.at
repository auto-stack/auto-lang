// Reverse-translated from godot-demo-projects/2d/kinematic_character/player/{player.gd,player.tscn} (Plan 308).
// A CharacterBody2D player with walk/jump physics.
//
// Translation notes (round-trip divergences from the original):
//  - `&"move_left"` / `&"jump"` StringName -> plain strings (no & literal in Auto).
//  - `var x := expr` -> `var x = expr` (Auto infers).
//  - `velocity.x += y` -> `velocity.x = velocity.x + y` (explicit field reassignment).
//  - `a and b` -> nested `if` (avoids relying on Auto's boolean-operator form).
scene Player : CharacterBody2D {
    script = "player.gd"

    node Sprite2D {
        texture = load("res://player/player.png")
    }

    node CollisionShape2D {
        position = Vector2(-0.315559, 0.157784)
        shape = RectangleShape2D {
            size = Vector2(14, 14)
        }
    }
}

const WALK_FORCE = 600
const WALK_MAX_SPEED = 200
const STOP_FORCE = 1300
const JUMP_SPEED = 200

#[onready]
var gravity = float(ProjectSettings.get_setting("physics/2d/default_gravity"))

fn _physics_process(delta f64) {
    // Horizontal movement code. First, get the player's input.
    var walk = WALK_FORCE * Input.get_axis("move_left", "move_right")
    // Slow down the player if they're not trying to move.
    if abs(walk) < WALK_FORCE * 0.2 {
        velocity.x = move_toward(velocity.x, 0, STOP_FORCE * delta)
    } else {
        velocity.x = velocity.x + walk * delta
    }
    // Clamp to the maximum horizontal movement speed.
    velocity.x = clamp(velocity.x, -WALK_MAX_SPEED, WALK_MAX_SPEED)

    // Vertical movement code. Apply gravity.
    velocity.y = velocity.y + gravity * delta

    // Move based on the velocity and snap to the ground.
    move_and_slide()

    // Check for jumping. is_on_floor() must be called after movement code.
    if is_on_floor() {
        if Input.is_action_just_pressed("jump") {
            velocity.y = -JUMP_SPEED
        }
    }
}
