// Lesson 13: Conditions — Comparison Operators
// Source: learn-gdscript/course/lesson-13-conditions
fn main() {
    let health = 100
    if health > 5 {
        print("health is greater than five")
    }
    if 1 < health {
        print("one is less than health")
    }
    if health == 100 {
        print("health is one hundred")
    }
    if health != 7 {
        print("health is not equal to seven")
    }
}
