// Custom random distribution for Pet enum
use.rust rand

enum Pet {
    Dog
    Cat
    Bird
}

fn random_pet(rng) Pet {
    let n = rng.gen_range(0..3)
    is n {
        0 -> Pet.Dog,
        1 -> Pet.Cat,
        else -> Pet.Bird
    }
}

fn main() {
    var rng = rand.thread_rng()
    let pet Pet = random_pet(rng)
    print("Got a pet!")
}
