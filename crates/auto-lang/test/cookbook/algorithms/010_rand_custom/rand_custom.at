// Custom random distribution for Color enum
use.rust rand

enum Color {
    Red
    Green
    Blue
}

fn random_color(rng) Color {
    let n = rng.gen_range(0..3)
    is n {
        0 -> Color.Red,
        1 -> Color.Green,
        else -> Color.Blue
    }
}

ext Color {
    fn debug_str() str {
        is self {
            Color.Red -> "Red",
            Color.Green -> "Green",
            Color.Blue -> "Blue"
        }
    }
}

fn main() {
    var rng = rand.thread_rng()
    let color Color = random_color(rng)
    print(f"Random color: ${color.debug_str()}")
}
