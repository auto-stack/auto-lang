// Custom enum demo
enum Color {
    Red int
    Green int
    Blue int
}

fn main() {
    var colors = List.new()
    colors.push(Color.Red(0))
    colors.push(Color.Green(1))
    colors.push(Color.Blue(2))
    for c in colors {
        is c {
            Color.Red(n) -> print("Red"),
            Color.Green(n) -> print("Green"),
            Color.Blue(n) -> print("Blue")
        }
    }
}
