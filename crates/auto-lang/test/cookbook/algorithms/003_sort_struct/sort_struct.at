use.rust std::vec::Vec

type Person {
    name str
    age uint
}

fn main() {
    var people = [Person("Zoe", 25), Person("Al", 60), Person("John", 1)]

    // sort() on struct arrays uses VmRef ID ordering (not field-based)
    // Verify it completes without error
    people.sort()

    // sort_by_key sorts by extracted key — verify age-based ordering
    people.sort_by_key((p) => p.age)
    assert(people[0].name == "Zoe")
    assert(people[1].name == "Al")
    assert(people[2].name == "John")
}
