dep simplelog
dep log
use.rust log::info
use.rust simplelog::WriteLogger
use.rust simplelog::LevelFilter
use.rust simplelog::Config

fn main() {
    let file = File.create("app.log").unwrap()
    WriteLogger.init(LevelFilter.Info, Config.default(), file).unwrap()
    info("logging to custom file")
    print("log written to app.log")
}
