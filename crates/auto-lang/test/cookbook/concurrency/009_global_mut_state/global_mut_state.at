use.rust std::sync::atomic::AtomicUsize
use.rust std::sync::atomic::Ordering
use.rust std::sync::Arc
use.rust std::thread

fn main() {
    let counter = Arc.new(AtomicUsize.new(0))
    let c1 = counter.clone()
    let c2 = counter.clone()
    let t1 = thread.spawn(_ => {
        for i in 0..100 {
            c1.fetch_add(1, Ordering.SeqCst)
        }
    })
    let t2 = thread.spawn(_ => {
        for i in 0..100 {
            c2.fetch_add(1, Ordering.SeqCst)
        }
    })
    t1.join().unwrap()
    t2.join().unwrap()
    print(f"Final count: ${counter.load(Ordering.SeqCst)}")
}
