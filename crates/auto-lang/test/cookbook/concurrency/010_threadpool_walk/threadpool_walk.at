dep walkdir
use.rust walkdir::WalkDir

// Thread pool directory walk — simplified for VM (WalkDir shim returns entries)
// Tests the pattern of collecting directory entries for parallel processing
fn main() {
    var dirs List<Str> = List.new()
    dirs.push("src/")
    dirs.push("docs/")
    dirs.push("test/")
    let count = dirs.len()
    assert(count == 3)
    for d in dirs {
        assert(d.len() > 0)
    }
}
