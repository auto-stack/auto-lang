// Parallel any/all test demo
fn main() {
    var data = List.new()
    data.push(1)
    data.push(5)
    data.push(10)
    data.push(2)
    var all_gt_0 = true
    var any_gt_5 = false
    for val in data {
        if val <= 0 { all_gt_0 = false }
        if val > 5 { any_gt_5 = true }
    }
    print(f"All > 0: ${all_gt_0}")
    print(f"Any > 5: ${any_gt_5}")
}
