// Postgres insert and query demo (simulated)

type Author {
    name str
    nationality str
}

fn main() {
    var authors List<Author> = List.new()
    authors.push(Author("J.G. Ballard", "UK"))
    authors.push(Author("George R.R. Martin", "USA"))

    for author in authors {
        print(f"${author.name} (${author.nationality})")
    }
    assert(true)
}
