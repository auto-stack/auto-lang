// SQLite insert and select demo (simulated)

type Cat {
    id int
    name str
    color str
}

fn main() {
    var cats List<Cat> = List.new()
    cats.push(Cat(1, "Michi", "Black"))
    cats.push(Cat(2, "Nori", "Orange"))
    cats.push(Cat(3, "Bacon", "Brown"))

    for cat in cats {
        print(f"Found cat ${cat.name} (${cat.color}) with id ${cat.id}")
    }
    assert(true)
}
