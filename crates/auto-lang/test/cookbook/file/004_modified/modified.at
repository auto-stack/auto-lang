dep walkdir
use.rust walkdir
use.rust std::fs

fn main() {
    for entry in walkdir.WalkDir.new("src").into_iter().filter_map(e => e.ok()) {
        if entry.file_type().is_file() {
            let meta = fs.metadata(entry.path()).unwrap()
            let modified = meta.modified().unwrap()
            print(f"${entry.path().display()}: ${modified}")
        }
    }
    assert(true)
}
