// Find recently modified files demo
fn main() {
    var files = List.new()
    files.push("file1.txt")
    files.push("file2.txt")
    files.push("file3.txt")
    var recent = List.new()
    for i in 0..files.len() {
        if i < 2 {
            recent.push(files.get(i))
        }
    }
    print(f"Recent files (${recent.len()}):")
    for f in recent {
        print(f"  ${f}")
    }
}
