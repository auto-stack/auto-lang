use.rust std::fs

fn main() {
    let content = "line1\nline2\nline3"
    let path = "test_temp.txt"
    File.write_text(path, content)
    let lines = File.read_text(path)
    var line_count = 0
    for line in lines.lines() {
        line_count += 1
    }
    assert(line_count == 3)
    File.delete(path)
}
