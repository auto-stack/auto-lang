use.rust std::fs

fn main() ! {
    let entries = fs.read_dir(".").?
    for entry in entries {
        let entry = entry.?
        let name = entry.file_name()
        let name_str = name.to_str().unwrap()
        if name_str.ends_with(".png") {
            print(f"PNG file: $name_str")
        }
    }
}
