use.rust std::fs

fn main() ! {
    let dir = fs.read_dir(".").?
    for entry in dir {
        let entry = entry.?
        let name = entry.file_name()
        let name_str = name.to_str().unwrap().to_lowercase()
        if name_str.ends_with(".txt") {
            print(f"Text file: $name_str")
        }
    }
}
