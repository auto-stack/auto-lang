// Case insensitive search demo
fn main() {
    var files = List.new()
    files.push("src/main.at")
    files.push("src/lib.rs")
    files.push(".gitignore")
    files.push("README.md")
    print(f"Total files: ${files.len()}")
    for f in files {
        if !f.starts_with(".") {
            print(f"  ${f}")
        }
    }
}
