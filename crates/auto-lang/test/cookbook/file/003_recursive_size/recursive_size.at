dep walkdir
use.rust walkdir::WalkDir
use.rust std::fs

fn main() {
    var total_size = 0
    for entry in WalkDir.new("src") {
        let entry = entry.unwrap()
        if entry.file_type().is_file() {
            let meta = fs.metadata(entry.path()).unwrap()
            total_size += meta.len()
        }
    }
    print(f"Total size: $total_size bytes")
}
