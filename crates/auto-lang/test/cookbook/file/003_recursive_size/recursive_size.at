dep walkdir
use.rust walkdir
use.rust std::fs

fn main() {
    var total_size uint = 0
    for entry in walkdir.WalkDir.new("src") {
        let entry = entry.unwrap()
        if entry.file_type().is_file() {
            let meta = fs.metadata(entry.path()).unwrap()
            total_size = total_size + meta.len()
        }
    }
    // Verify total_size was computed (non-negative)
    let has_size = total_size >= 0
    assert(has_size)
}
