use.rust std::collections::HashSet
use.rust std::path::PathBuf

fn visit(path PathBuf, visited HashSet<PathBuf>) {
    if !visited.contains(path) {
        visited.insert(path.clone())
    } else {
        print(f"Loop detected: ${path.display()}")
    }
}

fn main() {
    var visited HashSet<PathBuf> = HashSet.new()
    visit(PathBuf.from("."), visited)
}
