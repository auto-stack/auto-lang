// File and directory removal
fn main() ! {
    let _ = File.write_text("data.txt", "hello").?
    let _ = File.delete("data.txt").?
    let _ = File.create_dir("my_dir").?
    let _ = File.create_dir("my_dir/sub_dir").?
    let _ = File.remove_dir_all("my_dir").?
    print("Files and directories removed")
}
