// Async read/write traits demo (simulated)

fn write_data(path str, data str) {
    print(f"Wrote ${data.len()} bytes to ${path}")
}

fn read_data(path str) str {
    return "file contents here"
}

fn main() {
    write_data("data.txt", "Generated Data!")
    let contents = read_data("data.txt")
    print(f"Data Length: ${contents.len()}")
}
