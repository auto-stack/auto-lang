// Bounded channel pattern demo using List

type Book {
    title str
}

ext Book {
    static fn new(title str) Book {
        return Book(title)
    }
}

fn main() {
    var shelf List<Book> = List.new()
    shelf.push(Book.new("Shawshank Redemption"))
    shelf.push(Book.new("Secret Recipe"))

    for book in shelf {
        print(f"Title: ${book.title}")
    }
    assert(true)
}
