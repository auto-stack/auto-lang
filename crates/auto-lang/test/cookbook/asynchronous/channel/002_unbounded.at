// Unbounded channel pattern demo using List

type Message {
    from str
    text str
}

ext Message {
    static fn new(from str, text str) Message {
        return Message(from, text)
    }
}

fn main() {
    var inbox List<Message> = List.new()
    inbox.push(Message.new("Alice", "Meeting postponed"))
    inbox.push(Message.new("Bob", "Secret Leaked"))

    for msg in inbox {
        print(f"${msg.from} says: ${msg.text}")
    }
}
