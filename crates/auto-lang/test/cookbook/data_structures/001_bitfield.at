// Bitfield flag operations using Auto's bitwise methods
fn main() {
    let flag_a = 1
    let flag_b = 2
    let flag_c = 4

    var flags = 0
    flags = flags.or(flag_a)
    flags = flags.or(flag_b)
    assert(flags == 3)
    var has_a = flags.and(flag_a) != 0
    var has_c = flags.and(flag_c) != 0
    assert(has_a == true)
    assert(has_c == false)
    flags = flags.and(flag_a.not())
    assert(flags == 2)
}
