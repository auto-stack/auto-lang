// REST API GET demo (simulated)

type Stargazer {
    login str
    id uint
    starred_at str
}

fn main() {
    var stargazers List<Stargazer> = List.new()
    stargazers.push(Stargazer("user1", 1, "2024-01-01"))
    stargazers.push(Stargazer("user2", 2, "2024-01-02"))

    for sg in stargazers {
        print(f"${sg.login} starred at ${sg.starred_at}")
    }
}
