// REST API: inspect response headers
// Note: AutoVM Http.get performs a GET request; header inspection works the same way.

fn main() {
    let url = "https://httpbin.org/get"
    let handle = Http.get(url)
    let status = Response.status_code(handle)
    print(f"Status: ${status}")

    let ct = Response.header_get(handle, "Content-Type")
    print(f"Content-Type: ${ct}")

    let cl = Response.header_get(handle, "Content-Length")
    print(f"Content-Length: ${cl}")

    let server = Response.header_get(handle, "Server")
    print(f"Server: ${server}")
}
