// Paginated API request demo — fetch a page of results

fn main() {
    let url = "https://httpbin.org/get?page=1&per_page=5"
    let handle = http.get(url)
    let status = Response.status_code(handle)
    print(f"Page 1 status: ${status}")

    let body = Response.body(handle)
    print(f"Body length: ${body.len()}")

    // Check for next page link in headers
    let link_header = Response.header_get(handle, "Link")
    if link_header.len() > 0 {
        print(f"Link header: ${link_header}")
    } else {
        print("No Link header (single page)")
    }
    assert(true)
}
