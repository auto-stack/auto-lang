// HTTP Basic auth demo — unauthenticated request to auth endpoint

fn main() {
    // httpbin.org /basic-auth returns 401 without credentials
    let url = "https://httpbin.org/basic-auth/user/pass"

    let handle = http.get(url)
    let status = Response.status_code(handle)
    print(f"Status: ${status}")

    let body = Response.body(handle)
    print(f"Body length: ${body.len()}")
    assert(true)
}
