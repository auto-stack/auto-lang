// Partial/range download demo — simulate chunked reading

fn main() {
    let url = "https://httpbin.org/bytes/10240"
    let handle = http.get(url)
    let status = Response.status_code(handle)
    print(f"Status: ${status}")

    let body = Response.body(handle)
    let total = body.len()
    print(f"Total size: ${total} bytes")

    // Simulate chunked reading progress
    let chunk_size = 1024
    var downloaded = 0
    for downloaded < total {
        downloaded = downloaded + chunk_size
        if downloaded > total {
            downloaded = total
        }
        print(f"Downloaded ${downloaded}/${total}")
    }
}
