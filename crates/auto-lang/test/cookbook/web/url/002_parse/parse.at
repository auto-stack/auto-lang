dep url
use.rust url::Url

fn main() {
    let url = Url.parse("https://example.com/rust?name=hello&age=20").unwrap()
    // query_pairs() returns tuple iterator; use query() for raw string in Auto
    let query = url.query()
    print(f"Query string: ${query}")
    // Demonstrate pair iteration via query_pairs()
    let query = url.query()
    var pair_count = 0
    for pair in url.query_pairs() {
        pair_count += 1
    }
    assert(pair_count == 2)
}
