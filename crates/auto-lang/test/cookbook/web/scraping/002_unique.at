// Unique link collection demo — fetch pages and collect unique URLs

fn main() {
    var urls = List.new()
    urls.push("https://httpbin.org/html")
    urls.push("https://httpbin.org/json")
    urls.push("https://httpbin.org/html")

    // Visit each URL and print basic info
    var visited = 0
    for url in urls {
        let handle = http.get(url)
        let status = Response.status_code(handle)
        let body = Response.body(handle)
        print(f"${url} => status ${status}, length ${body.len()}")
        visited = visited + 1
    }
    print(f"Visited ${visited} URLs")
}
