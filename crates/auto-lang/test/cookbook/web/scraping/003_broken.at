// Broken link detection demo — check status codes for multiple URLs

fn main() {
    var urls = List.new()
    urls.push("https://httpbin.org/status/200")
    urls.push("https://httpbin.org/status/404")
    urls.push("https://httpbin.org/status/500")

    for url in urls {
        let handle = http.get(url)
        let status = Response.status_code(handle)
        if status == 200 {
            print(f"OK: ${url} (${status})")
        } else {
            print(f"BROKEN: ${url} (${status})")
        }
    }
}
