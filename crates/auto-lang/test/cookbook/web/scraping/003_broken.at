// Broken link detection demo (simulated)

fn main() {
    var urls List<str> = List.new()
    urls.push("https://httpbin.org/status/200")
    urls.push("https://httpbin.org/status/404")

    var status200 = 200
    var status404 = 404

    print(f"OK: ${urls.get(0)} (${status200})")
    print(f"BROKEN: ${urls.get(1)} (${status404})")
}
