// MIME type handling demo — inspect Content-Type header

fn main() {
    let url = "https://httpbin.org/json"
    let handle = http.get(url)
    let status = Response.status_code(handle)
    assert(status == 200)

    let content_type = Response.header_get(handle, "Content-Type")
    assert(content_type.contains("json"))

    // Parse MIME type into type/subtype
    let parts = content_type.split("/")
    assert(parts.get(0) == "application")
}
