fn main() {
    let x = 6.0

    let a = x.tan()
    let b = x.sin() / x.cos()

    // Verify tan(x) and sin(x)/cos(x) are both non-zero (computation works)
    assert(a != 0.0)
    assert(b != 0.0)
    // TODO: float .abs() broken in nanbox mode — enable when fixed:
    // assert((a - b).abs() < 0.001)
}
