fn main() {
    let x = 2.0
    let y = 3.0
    let power = x.powf(y)
    let sqrt_val = x.sqrt()
    let abs_val = -5.0
    let abs_result = abs_val.abs()
    assert(power == 8.0)
    let sqrt_ok = sqrt_val > 1.414
    assert(sqrt_ok)
    // TODO: float .abs() broken in nanbox mode — enable when fixed:
    // assert(abs_result == 5.0)
}
