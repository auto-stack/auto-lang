fn main() {
    let a = [[1.0, 2.0], [3.0, 4.0]]
    let det = a[0][0] * a[1][1] - a[0][1] * a[1][0]
    var inv = [[0.0, 0.0], [0.0, 0.0]]
    inv[0][0] = a[1][1] / det
    inv[0][1] = -a[0][1] / det
    inv[1][0] = -a[1][0] / det
    inv[1][1] = a[0][0] / det
    print(f"Inverse: ${inv[0][0]} ${inv[0][1]}")
    print(f"         ${inv[1][0]} ${inv[1][1]}")
}
