dep semver
use.rust semver::Version
use.rust semver::VersionReq

fn main() {
    let req = VersionReq.parse(">=1.2.0, <2.0.0").unwrap()
    let v1 = Version.parse("1.5.0").unwrap()
    let v2 = Version.parse("2.0.0").unwrap()
    let m1 = req.matches(v1)
    let m2 = req.matches(v2)
    assert(m1 == true)
    assert(m2 == false)
}
