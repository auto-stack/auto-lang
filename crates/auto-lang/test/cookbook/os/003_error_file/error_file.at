use.rust std::fs::File
use.rust std::process::{Command, Stdio}

fn main() ! {
    let outputs = File.create("out.txt").?
    let errors = outputs.try_clone().?

    Command.new("ls")
        .args([".", "oops"])
        .stdout(Stdio.from(outputs))
        .stderr(Stdio.from(errors))
        .spawn().?
        .wait_with_output().?
}
