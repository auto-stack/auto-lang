// CSV transform demo
fn main() {
    var names = List.new()
    names.push("Alice")
    names.push("Bob")
    names.push("Charlie")
    var ages = List.new()
    ages.push(30)
    ages.push(25)
    ages.push(35)
    for i in 0..names.len() {
        let age = ages.get(i)
        print(f"${names.get(i)},${age},${age / 10 * 10}s")
    }
}
