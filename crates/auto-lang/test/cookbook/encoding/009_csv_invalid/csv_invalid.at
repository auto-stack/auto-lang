// CSV invalid data handling demo
fn main() {
    var names = List.new()
    names.push("Alice")
    names.push("Bob")
    var ages = List.new()
    ages.push(30)
    ages.push(-1)
    for i in 0..names.len() {
        let age = ages.get(i)
        if age >= 0 {
            print(f"${names.get(i)}: ${age}")
        } else {
            print(f"Invalid age for ${names.get(i)}")
        }
    }
}
