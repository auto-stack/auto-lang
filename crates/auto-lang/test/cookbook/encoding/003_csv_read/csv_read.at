// CSV reading demo using Auto List and string operations
fn main() {
    var rows = List.new()
    rows.push("name,age")
    rows.push("Alice,30")
    rows.push("Bob,25")

    print(f"Header: ${rows.get(0)}")
    for i in 1..rows.len() {
        let row = rows.get(i)
        var cols = row.split(",")
        print(f"Name: ${cols.get(0)}, Age: ${cols.get(1)}")
    }
}
