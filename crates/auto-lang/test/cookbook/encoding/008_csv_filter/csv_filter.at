// CSV filtering demo
fn main() {
    var names = List.new()
    names.push("Alice")
    names.push("Bob")
    names.push("Charlie")
    var ages = List.new()
    ages.push(30)
    ages.push(25)
    ages.push(35)
    for i in 0..names.len() {
        let age = ages.get(i)
        if age >= 30 {
            print(f"${names.get(i)}: ${age}")
        }
    }
}
