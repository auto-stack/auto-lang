// Tar with prefix stripping demo
fn main() {
    let prefix = "backup/"
    var files = List.new()
    files.push("backup/file1.txt")
    files.push("backup/file2.txt")
    for f in files {
        if f.starts_with(prefix) {
            let stripped = f.substr(prefix.len(), f.len() - prefix.len())
            print(f"${f} -> ${stripped}")
        }
    }
}
