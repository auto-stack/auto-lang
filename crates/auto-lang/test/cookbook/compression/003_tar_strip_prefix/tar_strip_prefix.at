dep flate2
dep tar
use.rust flate2::read::GzDecoder
use.rust std::fs::File
use.rust tar::Archive

fn main() {
    let file = File.open("archive.tar.gz").unwrap()
    let gz = GzDecoder.new(file)
    var archive = Archive.new(gz)
    archive.set_prefix_strip(3)
    for entry in archive.entries().unwrap() {
        let entry = entry.unwrap()
        print(f"Extracted: ${entry.path().unwrap().display()}")
    }
}
