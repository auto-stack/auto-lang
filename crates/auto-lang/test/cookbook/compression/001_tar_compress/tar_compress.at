// Tar compression demo
fn main() {
    var entries = List.new()
    entries.push("backup/file1.txt")
    entries.push("backup/file2.txt")
    entries.push("backup/subdir/file3.txt")
    print(f"Archive contains ${entries.len()} entries")
    for entry in entries {
        print(f"  ${entry}")
    }
}
