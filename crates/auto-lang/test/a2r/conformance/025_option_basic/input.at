// Conformance 025: Option type basics
fn maybe(x int) ?int {
    if x > 0 {
        return Some(x)
    }
    return None
}

fn main() {
    let a = maybe(5)
    let b = maybe(-1)
    is a {
        Some(v) -> print(v),
        None -> print("none")
    }
    is b {
        Some(v) -> print(v),
        None -> print("none")
    }
}
