// Conformance 015: Nested if/else
fn main() {
    let x = 15
    if x > 20 {
        print("big")
    } else if x > 10 {
        print("medium")
    } else if x > 5 {
        print("small")
    } else {
        print("tiny")
    }
    if x > 10 {
        if x > 20 {
            print("huge")
        } else {
            print("ok")
        }
    }
}
