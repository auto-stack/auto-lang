dep tokio
use.rust tokio::fs::read
use.rust tokio::fs::read_to_string

fn process_data(data []byte) {
    print(f"Data Length: ${data.len()}")
}

fn main() ! ~void {
    let content = read("data.txt").await.?
    process_data(content)

    let str_content = read_to_string("data.txt").await.?
    print(f"Text: ${str_content}")
}
