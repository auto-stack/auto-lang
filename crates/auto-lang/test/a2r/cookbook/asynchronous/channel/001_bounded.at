dep tokio
use.rust tokio::sync::mpsc::channel

type Book {
    title str
}

ext Book {
    static fn new(title str) Book {
        return Book(title)
    }
}

fn main() ~void {
    let ch = channel(5)
    let sender = ch.sender
    let receiver = ch.receiver

    sender.send(Book.new("Shawshank Redemption")).await
    sender.send(Book.new("Secret Recipe")).await

    print(f"Sent 2 books")

    for book in ["Shawshank Redemption", "Secret Recipe"] {
        print(f"Title: ${book}")
    }
}
