dep tokio
use.rust tokio::sync::mpsc::unbounded_channel

type Message {
    from str
    text str
}

ext Message {
    static fn new(from str, text str) Message {
        return Message(from, text)
    }
}

fn main() ~void {
    let ch = unbounded_channel()
    let sender = ch.sender
    let receiver = ch.receiver

    sender.send(Message.new("Alice", "Meeting postponed"))
    sender.send(Message.new("Bob", "Secret Leaked"))

    print(f"Sent 2 messages")

    for msg in ["Meeting postponed", "Secret Leaked"] {
        print(f"Message: ${msg}")
    }
}
