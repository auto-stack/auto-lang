dep reqwest
use.rust reqwest
use.rust scraper::Html
use.rust scraper::Selector

fn main() ! ~void {
    let html_content = "<html><body><a href='https://httpbin.org/status/200'>OK</a><a href='https://httpbin.org/status/404'>Missing</a></body></html>"
    let html = Html.parse_document(html_content)
    let selector = Selector.parse("a[href]").?
    let client = reqwest.Client.new()

    for element in html.select(selector) {
        let href = element.attr("href") ?? ""
        let response = client.head(href).send().await.?
        let status = response.status().as_u16()
        if status >= 400 {
            print(f"BROKEN: ${href} (${status})")
        } else {
            print(f"OK: ${href} (${status})")
        }
    }
}
