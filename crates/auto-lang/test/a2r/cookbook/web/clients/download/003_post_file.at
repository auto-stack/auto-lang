dep reqwest
use.rust reqwest
use.rust std::fs::read

fn main() ! ~void {
    let content = read("message.txt").?
    let client = reqwest.Client.new()

    let response = client.post("https://paste.rs/")
        .body(content)
        .send()
        .await.?

    let url = response.text().await.?
    print(f"Uploaded to: ${url}")
}
