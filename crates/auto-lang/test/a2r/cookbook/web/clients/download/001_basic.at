use.rust reqwest
use.rust std::fs::File
use.rust std::io::Write

fn main() ! ~void {
    let response = reqwest.get("https://example.com/file.zip").await?
    let bytes = response.bytes().await?

    let mut out = File.create("file.zip")?
    out.write_all(bytes)?

    print(f"Downloaded ${bytes.len()} bytes")
}
