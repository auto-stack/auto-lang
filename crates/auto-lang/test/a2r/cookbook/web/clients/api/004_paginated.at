dep reqwest
use.rust reqwest

fn main() ! ~void {
    let client = reqwest.Client.new()
    var page = 1

    let url = f"https://crates.io/api/v1/crates/serde/reverse_dependencies?page=${page}"
    let response = client.get(url)
        .header("User-Agent", "reqwest-example")
        .send()
        .await.?

    print(f"Status: ${response.status()}")
}
