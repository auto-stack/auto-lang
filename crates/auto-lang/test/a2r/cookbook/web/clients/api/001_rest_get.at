dep reqwest
use.rust reqwest

type Stargazer {
    login str
    id uint
    starred_at str
}

fn main() ! ~void {
    let client = reqwest.Client.new()
    let response = client.get("https://api.github.com/repos/rust-lang/rust/stargazers")
        .header("User-Agent", "reqwest-example")
        .send()
        .await.?

    let stargazers = response.json(List<Stargazer>).await.?
    for sg in stargazers {
        print(f"${sg.login} starred at ${sg.starred_at}")
    }
}
