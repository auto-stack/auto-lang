dep reqwest
use.rust reqwest

fn main() ! ~void {
    let client = reqwest.Client.new()

    let response = client.post("https://api.github.com/gists")
        .header("User-Agent", "reqwest-example")
        .basic_auth("user", "token")
        .send()
        .await.?

    print(f"Status: ${response.status()}")
}
