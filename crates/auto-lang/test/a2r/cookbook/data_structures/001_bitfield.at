fn main() {
    let flag_a = 1
    let flag_b = 2
    let flag_c = 4
    var flags = 0
    flags = flags + flag_a
    flags = flags + flag_b
    print(f"Flags: ${flags}")
    print(f"Has A: ${(flags % 2) == 1}")
    print(f"Has C: ${flags >= flag_c}")
    flags = flags - flag_a
    print(f"After clear A: ${flags}")
}
