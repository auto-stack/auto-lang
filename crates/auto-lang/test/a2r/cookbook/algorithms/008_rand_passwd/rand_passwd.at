use.rust rand::Rng
use.rust rand::thread_rng

fn main() {
    var rng = thread_rng()
    let charset = "abcdefghijklmnopqrstuvwxyz"
    var password = ""
    for _ in 0..16 {
        let idx = rng.gen_range(0..charset.len())
        let ch = charset.chars().nth(idx).unwrap()
        password = password + ch.to_string()
    }
    print(f"Password: $password")
}
