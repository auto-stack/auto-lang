dep tokio
use.rust tokio::sync::mpsc::channel
use.rust tokio::sync::oneshot

type DriverStatus {
    driver_id uint
    lat f64
    lng f64
    update_count uint
}

ext DriverStatus {
    static fn new(driver_id uint) DriverStatus {
        return DriverStatus(driver_id, 0.0, 0.0, 0)
    }
}

fn main() ! ~void {
    print("Actor pattern demo")
}
