use.rust csv::Writer
use.rust serde::Serialize

type Record {
    name str
    age i32
}

fn main() ! {
    let records = [Record("Alice", 30), Record("Bob", 25)]
    var writer = Writer.from_writer(Vec.new())
    for record in records {
        writer.serialize(record).?
    }
    let output = String.from_utf8(writer.into_inner().?).?
    print(output)
}
