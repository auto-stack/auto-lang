// Test Tabs pattern with state
widget TestTabs {
    model { activeTab str = "tab1" }

    view {
        col {
            tabs {
                TabsList {
                    TabsTrigger "tab1" (label: "Tab 1") {}
                    TabsTrigger "tab2" (label: "Tab 2") {}
                }
                TabsContent "tab1" {
                    text "Content 1"
                }
                TabsContent "tab2" {
                    text "Content 2"
                }
            }
        }
    }
}
