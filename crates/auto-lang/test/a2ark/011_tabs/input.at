widget TestTabs {
    view {
        col (class: "gap-4 p-4") {
            text (text: "Tab Navigation", class: "text-lg font-bold") {}
            tabs {
                TabsList {
                    TabsTrigger "home" (label: "Home") {}
                    TabsTrigger "settings" (label: "Settings") {}
                }
                TabsContent "home" {
                    text "Welcome to the home page"
                }
                TabsContent "settings" {
                    text "Settings page"
                }
            }
        }
    }
}
