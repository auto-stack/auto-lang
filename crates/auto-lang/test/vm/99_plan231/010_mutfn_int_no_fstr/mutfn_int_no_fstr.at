// Test: mut fn returning int, no f-string
type Counter {
    count int

    mut fn next() int {
        self.count = self.count - 1
        return self.count
    }
}

fn main() {
    var c = Counter(3)
    let v1 = c.next()
    print(v1)
    let v2 = c.next()
    print(v2)
    print("mutfn int no fstr OK")
}
