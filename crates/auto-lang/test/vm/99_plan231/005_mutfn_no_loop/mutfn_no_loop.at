// Test: mut fn without for loop
type Counter {
    count int

    mut fn next() ?int {
        if self.count > 0 {
            self.count = self.count - 1
            return Some(self.count + 1)
        }
        return None
    }
}

fn main() {
    var c = Counter(2)
    let v1 = c.next()
    print(f"v1: $v1")
    let v2 = c.next()
    print(f"v2: $v2")
    let v3 = c.next()
    print(f"v3: $v3")
    print("mutfn no loop OK")
}
