// Exact copy of vmtest-09-self-field.at
type Counter {
    count int

    mut fn increment() void {
        self.count = self.count + 1
    }

    fn get_count() int {
        return self.count
    }
}

fn main() {
    print("=== Self field access test ===")
    var c = Counter(0)
    c.increment()
    c.increment()
    c.increment()
    let n = c.get_count()
    print(f"count: $n")
}
