enum ParseError {
    InvalidChar { ch str, pos int }
    UnexpectedEnd
}

fn parse(s str) !int {
    if s == "" {
        return Err(ParseError.UnexpectedEnd)
    }
    Ok(42)
}

let r = parse("")
is r {
    Ok(n) -> print(n)
    Err(e) -> {
        is e {
            ParseError.UnexpectedEnd -> print("unexpected end")
            else -> print("other error")
        }
    }
}

let r2 = parse("hello")
is r2 {
    Ok(n) -> print(n)
    Err(e) -> print("error")
}
