// Test: multi-field enum variant destructuring
fn main() {
    enum Shape {
        Point
        Rect { w int, h int }
        Circle { r int }
    }

    let s = Shape.Rect(10, 20)
    is s {
        Shape.Rect(w, h) -> {
            print(w)
            print(h)
        }
    }

    let c = Shape.Circle(5)
    is c {
        Shape.Circle(r) -> print(r)
    }

    let p = Shape.Point
    is p {
        Shape.Point -> print("point")
    }
}
