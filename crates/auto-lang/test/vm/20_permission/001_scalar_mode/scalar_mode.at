enum PermissionMode { Allow = 1, Ask = 2, ReadOnly = 3 }

type PermissionPolicy {
    mode int
}

fn check(policy_mode int, is_read_only bool) int {
    is policy_mode {
        1 -> 1
        3 -> {
            if is_read_only { 1 } else { 0 }
        }
        2 -> 1
        else -> 0
    }
}

let allow = PermissionPolicy { mode: 1 }
assert_eq(check(allow.mode, false), 1)

let ro = PermissionPolicy { mode: 3 }
assert_eq(check(ro.mode, true), 1)
assert_eq(check(ro.mode, false), 0)

print("permission scalar mode: ok")
