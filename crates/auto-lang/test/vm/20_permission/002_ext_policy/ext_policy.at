type PermissionPolicy {
    mode int
}

fn new_policy(mode int) PermissionPolicy {
    PermissionPolicy { mode: mode }
}

fn check(mode int, is_read_only bool) int {
    is mode {
        1 -> 1
        3 -> {
            if is_read_only { 1 } else { 0 }
        }
        2 -> 1
        else -> 0
    }
}

let allow = new_policy(1)
print(check(allow.mode, false))
print(check(allow.mode, true))

let ro = new_policy(3)
print(check(ro.mode, true))
print(check(ro.mode, false))

let ask = new_policy(2)
print(check(ask.mode, false))
