fn main() {
    var result = run_a2r("fn main() {\nlet x = 5\nif x > 3 {\nprint(\"big\")\n} else {\nprint(\"small\")\n}\n}")
    var expected = "fn main() {\n    let x = 5;\n    if (x > 3) {\n        println!(\"big\");\n    } else {\n        println!(\"small\");\n    }\n}\n"
    if result == expected {
        print("ok")
    } else {
        print("fail:" + result)
    }
}
