fn main() {
    var result = run_a2r("fn main() {\nvar x = 1\nis x {\n1 -> {\nprint(\"a\")\nprint(\"b\")\n}\nelse -> print(\"c\")\n}\n}")
    var expected = "fn main() {\n    let mut x = 1;\n    match x {\n        1 => {\n            println!(\"a\");\n            println!(\"b\");\n        },\n        _ => println!(\"c\"),\n    }\n}\n"
    if result == expected {
        print("ok")
    } else {
        print("fail:" + result)
    }
}
