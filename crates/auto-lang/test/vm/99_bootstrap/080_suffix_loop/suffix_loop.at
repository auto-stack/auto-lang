fn main() {
    // Manually replicate codegen_extract_method_suffix loop with prints
    var callee = "s.len"
    var suffix = ".len"
    var sn = suffix.len()
    var cn = callee.len()
    print("cn:")
    print(cn)
    print("sn:")
    print(sn)
    var start = cn - sn
    print("start:")
    print(start)

    var i = 0
    for i < sn {
        var a = callee.char_at(start + i)
        var b = suffix.char_at(i)
        print("i:")
        print(i)
        print("a:")
        print(a)
        print("b:")
        print(b)
        print("eq:")
        print(a == b)
        i = i + 1
    }
}
