fn main() {
    var result = run_a2r("fn main() {\nvar x = 10\nis x {\n10 -> print(\"a\")\nelse -> print(\"b\")\n}\n}")
    var expected = "fn main() {\n    let mut x = 10;\n    match x {\n        10 => println!(\"a\"),\n        _ => println!(\"b\"),\n    }\n}\n"
    if result == expected {
        print("ok")
    } else {
        print("fail:" + result)
    }
}
