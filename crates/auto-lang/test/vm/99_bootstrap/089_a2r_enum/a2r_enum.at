fn main() {
    var result = run_a2r("enum Color {\nRED = 1\nGREEN = 2\n}\nfn main() {\nprint(42)\n}")
    var expected = "#[derive(Clone, Debug, PartialEq)]\nenum Color {\n    RED = 1,\n    GREEN = 2,\n}\nfn main() {\n    println!(\"{}\", 42);\n}\n"
    if result == expected {
        print("ok")
    } else {
        print("fail:" + result)
    }
}
