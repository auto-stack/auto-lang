// Test: if-else — if true { 1 } else { 2 }
fn main() {
    let source = "if true {\n    1\n} else {\n    2\n}"
    let tokens = tokenize_list(source)
    let p = parser_new(tokens)
    let stmts = parse_program(p)
    var i = 0
    for i < stmts.len() {
        print(ast_to_string(stmts.get(i)))
        i = i + 1
    }
}
