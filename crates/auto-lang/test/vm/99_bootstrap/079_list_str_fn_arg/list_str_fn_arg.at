fn main() {
    var result = run_bytecode("fn main() {\nvar list = List.new()\nlist.push(\"alpha\")\nlist.push(\"beta\")\nvar s = list.get(0)\nprint(s)\nvar combined = s + \"!\"\nprint(combined)\n}")
    if result == "alpha\nalpha!\n" {
        print("ok")
    } else {
        print("fail:" + result)
    }
}
