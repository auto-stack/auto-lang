fn main() {
    var result = run_bytecode("fn main() {\nvar a = \"hello\"\nvar b = \"world\"\nvar c = a + b\nprint(c)\nprint(c.len())\nprint(c.substr(0, 5))\nprint(c.substr(5, 10))\n}")
    if result == "helloworld\n10\nhello\nworld\n" {
        print("ok")
    } else {
        print("fail:" + result)
    }
}
