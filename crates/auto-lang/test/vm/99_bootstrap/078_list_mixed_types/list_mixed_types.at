fn main() {
    var result = run_bytecode("fn main() {\nvar nums = List.new()\nnums.push(10)\nnums.push(20)\nvar strs = List.new()\nstrs.push(\"x\")\nstrs.push(\"y\")\nprint(nums.get(0))\nprint(strs.get(1))\nprint(nums.len())\nprint(strs.len())\n}")
    if result == "10\ny\n2\n2\n" {
        print("ok")
    } else {
        print("fail:" + result)
    }
}
