fn main() {
    var result = run_a2r("fn main() {\nvar name = \"Auto\"\nprint(f\"Hello $name\")\n}")
    var expected = "fn main() {\n    let mut name: String = \"Auto\".to_string();\n    println!(\"{}\", format!(\"Hello {}\", name));\n}\n"
    if result == expected {
        print("ok")
    } else {
        print("fail:" + result)
    }
}
