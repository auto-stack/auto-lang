fn main() {
    // Two str params + loop + char_at(start + i)
    fn test(a str, b str) int {
        var start = 1
        var i = 0
        for i < 4 {
            var v = a.char_at(start + i)
            if v == 0 { return 0 }
            i = i + 1
        }
        return 1
    }
    print(test("s.len", ".len"))
}
