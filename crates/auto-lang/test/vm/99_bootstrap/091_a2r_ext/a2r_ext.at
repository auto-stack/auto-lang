fn main() {
    var result = run_a2r("type Point {\nx int\ny int\n}\next Point {\nfn x() int {\nreturn 1\n}\n}\nfn main() {\nprint(42)\n}")
    var expected = "#[derive(Clone, Debug, PartialEq)]\nstruct Point {\n    x: i32,\n    y: i32,\n}\nimpl Point {\n    fn x(&self) -> i32 {\n        return 1;\n    }\n}\nfn main() {\n    println!(\"{}\", 42);\n}\n"
    if result == expected {
        print("ok")
    } else {
        print("fail:" + result)
    }
}
