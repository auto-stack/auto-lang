fn main() {
    // Test 1: nested function with char_at but no loop
    fn get_dot(s str) int {
        return s.char_at(1)
    }
    print(get_dot("s.len"))

    // Test 2: nested function with loop but no char_at
    fn count_to(n int) int {
        var sum = 0
        var i = 0
        for i < n {
            sum = sum + i
            i = i + 1
        }
        return sum
    }
    print(count_to(4))

    // Test 3: nested function with loop + char_at + variable index
    fn char_at_loop(s str) int {
        var start = 1
        var i = 0
        var total = 0
        for i < 4 {
            total = total + s.char_at(start + i)
            i = i + 1
        }
        return total
    }
    print(char_at_loop("s.len"))
}
