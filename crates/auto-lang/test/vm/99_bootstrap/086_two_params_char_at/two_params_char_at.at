fn main() {
    // Minimal: two str params, char_at on first param with (start + i)
    fn test(a str, b str) int {
        var start = 1
        var i = 0
        return a.char_at(start + i)
    }
    print(test("s.len", ".len"))

    // Same but only one param
    fn test2(a str) int {
        var start = 1
        var i = 0
        return a.char_at(start + i)
    }
    print(test2("s.len"))
}
