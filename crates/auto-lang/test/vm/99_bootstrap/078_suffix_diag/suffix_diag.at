fn main() {
    // Test suffix matching exactly as codegen would do it
    var callee = "s.len"
    var suffix = ".len"
    var r = codegen_extract_method_suffix(callee, suffix)
    print("suffix match:")
    print(r)

    // Test extract_var_name
    var vn = codegen_extract_var_name(callee)
    print("var_name:" + vn + ":")

    // Test type_lookup
    var source = "fn main() {\nvar s = \"hello\"\nprint(s.len())\n}"
    var tokens = tokenize_list(source)
    var p = parser_new(tokens)
    var stmts = parse_program(p)
    var tenv = typeenv_new()
    type_infer_program(tenv, stmts)
    var t = type_lookup(tenv, "s")
    print("type_of_s:")
    print(t)

    // If suffix matches and type is str, we should get OP_STR_LEN (76)
    if r == 1 && t == 1 {
        print("would_emit_OP_STR_LEN")
    } else {
        print("would_emit_OP_LIST_LEN")
    }
}
