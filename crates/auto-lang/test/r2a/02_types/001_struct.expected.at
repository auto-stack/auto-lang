type Point {
    x int
    y int
}

type Circle {
    radius float
    border uint
    center Point
}

fn main() {
    var p = Point(x: 1, y: 2)
    p.x = 3
    print(f"P: ${p . x}, ${p . y}")
    let circle = Circle(radius: 5.0, border: 1, center: Point(x: 50, y: 50))
    print(f"C: ${circle . center . x}, ${circle . center . y}, ${circle . radius}")
}
