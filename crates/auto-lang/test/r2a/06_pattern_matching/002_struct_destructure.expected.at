type Point {
    x int
    y int
}

enum Shape {
    Circle(int)
    Rect(Point)
    None
}

fn main() {
    let p = Point(x: 3, y: 4)
    is p {
        Point(x, y) => print(x)
    }
    let s = Rect(p)
    is s {
        Circle(r) => print(r)
        Rect(pt) => is pt {
            Point(x, y) => print(x)
        }
        None => print("none")
    }
}
