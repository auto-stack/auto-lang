""" The Planner role.
 Auto port of builtin_roles/planner.rs.
"""

use role_def: Role
use ai_config: ModelTier

""" Soul marker (full soul loaded from resources in Rust original).
"""
const SOUL = "Soul of the Planner"

pub type Planner has Role {
    pub fn name() str { return "planner" }
    pub fn system_prompt() str { return SOUL }
    pub fn model_tier() ModelTier { return ModelTier.Pro }
    pub fn temperature() float { return 0.3 }
    pub fn max_turns() uint { return 40 }
}
