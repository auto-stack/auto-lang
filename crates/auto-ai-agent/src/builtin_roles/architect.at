""" The Architect role.
 Auto port of builtin_roles/architect.rs.
"""

use role_def: Role
use ai_config: ModelTier

""" Soul marker (full soul loaded from resources in Rust original).
"""
const SOUL = "Soul of the Architect"

pub type Architect has Role {
    pub fn name() str { return "architect" }
    pub fn system_prompt() str { return SOUL }
    pub fn model_tier() ModelTier { return ModelTier.Max }
    pub fn temperature() float { return 0.2 }
    pub fn max_turns() uint { return 40 }
    pub fn handoff_to() List<str> { return ["planner", "coder"] }
}
