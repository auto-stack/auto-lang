""" The Supercoder role.
 Auto port of builtin_roles/super_coder.rs.
"""

use role_def: Role
use ai_config: ModelTier

""" Soul marker (full soul loaded from resources in Rust original).
"""
const SOUL = "Soul of the Supercoder"

pub type Supercoder has Role {
    pub fn name() str { return "super-coder" }
    pub fn system_prompt() str { return SOUL }
    pub fn model_tier() ModelTier { return ModelTier.Max }
    pub fn temperature() float { return 0.3 }
    pub fn max_turns() uint { return 120 }
}
