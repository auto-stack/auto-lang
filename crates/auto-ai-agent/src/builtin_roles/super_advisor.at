""" The Superadvisor role.
 Auto port of builtin_roles/super_advisor.rs.
"""

use role_def: Role
use ai_config: ModelTier

""" Soul marker (full soul loaded from resources in Rust original).
"""
const SOUL = "Soul of the Superadvisor"

pub type Superadvisor has Role {
