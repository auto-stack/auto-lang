#[spec(category = Overlay, has_children = true)]
#[backend(ark, component = "AlertDialogFooter")]
#[backend(jet, component = "Row", import = "androidx.compose.foundation.layout.Row")]
#[backend(vue, component = "div")]

/// AlertDialog footer section.
///
/// Contains action buttons at the bottom of the alert dialog.
widget AlertDialogFooter {
    view {}
