#[spec(category = Overlay, has_children = false, primary_prop = "text")]
#[backend(ark, component = "AlertDialogDescription")]
#[backend(jet, component = "Text", import = "androidx.compose.material3.Text")]
#[backend(vue, component = "p")]

/// AlertDialog description.
///
/// A description or additional context for the alert dialog.
widget AlertDialogDescription {
    view {}
}

#[spec(category = Overlay, has_children = false, primary_prop = "text")]
#[backend(ark, component = "AlertDialogAction")]
#[backend(jet, component = "Button", import = "androidx.compose.material3.Button")]
#[backend(vue, component = "button")]

/// AlertDialog action button (confirm).
///
/// The primary action button that confirms the alert dialog.
widget AlertDialogAction {
    view {}
