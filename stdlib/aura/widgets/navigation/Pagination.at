// stdlib/aura/widgets/navigation/Pagination.at

// ============================================================================
// Pagination - Main container
// ============================================================================

#[spec(category = Navigation, has_children = true, primary_prop = "page")]
#[backend(ark, component = "Pagination")]
#[backend(jet, component = "Row", import = "androidx.compose.foundation.layout.Row")]
#[backend(vue, component = "nav")]

/// Pagination component for page navigation.
///
/// A navigation component for moving between pages of content.
/// Supports first, previous, next, last, and numbered page buttons.
///
/// # Features
/// - Page number navigation
/// - Previous/Next buttons
/// - First/Last buttons
/// - Ellipsis for large page counts
/// - Accessible navigation
///
/// # Example
/// ```auto
/// Pagination (page: .currentPage, total: .totalPages) {
///     PaginationFirst {}
///     PaginationPrevious {}
///     PaginationItem (text: "1", active: .currentPage == 1) {}
///     PaginationEllipsis {}
///     PaginationItem (text: f"${.currentPage}") {}
///     PaginationEllipsis {}
///     PaginationItem (text: f"${.totalPages}") {}
///     PaginationNext {}
///     PaginationLast {}
/// }
/// ```
widget Pagination {
    msg Msg {
        Change(page: int)
        First
        Last
        Previous
        Next
    }

    model {
        page int = 1
        total int = 10
        perPage int = 10
    }

    view {
        tag: "nav"
        style: "pagination"
        role: "navigation"
        aria-label: "pagination"
    }
}

// ============================================================================
// PaginationFirst - First page button
// ============================================================================

#[spec(category = Navigation, has_children = false)]
#[backend(ark, component = "PaginationFirst")]
#[backend(jet, component = "IconButton", import = "androidx.compose.material3.IconButton")]
#[backend(vue, component = "button")]

/// Pagination first page button.
///
/// Navigates to the first page.
///
/// # Example
/// ```auto
/// PaginationFirst {}
/// ```
widget PaginationFirst {
    msg Msg { Click }

    view {
        tag: "button"
        style: "pagination-first"
        variant: "ghost"
        size: "icon"
    }
}

