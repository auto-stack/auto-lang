// ============================================================================
// PaginationItem - Page number button
// ============================================================================

#[spec(category = Navigation, has_children = false, primary_prop = "text")]
#[backend(ark, component = "PaginationItem")]
#[backend(jet, component = "FilterChip", import = "androidx.compose.material3.FilterChip")]
#[backend(vue, component = "button")]

/// Pagination page number button.
///
/// Displays a specific page number.
///
/// # Example
/// ```auto
/// PaginationItem (text: "1", active: true) {}
/// ```
widget PaginationItem {
    msg Msg { Click }

    model {
        text str = "1"
        active bool = false
    }

    computed {
        itemClass => if .active {
            "pagination-item active"
        } else {
            "pagination-item"
        }
    }

    view {
        tag: "button"
        style: .itemClass
        text: .text
    }
}

// ============================================================================
// PaginationEllipsis - Ellipsis indicator
// ============================================================================

#[spec(category = Navigation, has_children = false)]
#[backend(ark, component = "PaginationEllipsis")]
#[backend(jet, component = "Text", import = "androidx.compose.material3.Text")]
#[backend(vue, component = "span")]

/// Pagination ellipsis indicator.
///
/// Indicates skipped pages in the pagination.
///
/// # Example
/// ```auto
/// PaginationEllipsis {}
/// ```
widget PaginationEllipsis {
    view {
        tag: "span"
        style: "pagination-ellipsis"
        text: "..."
    }
}
