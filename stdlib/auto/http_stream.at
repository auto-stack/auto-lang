/// Plan 152: 流式 HTTP 客户端
///
/// 提供流式 HTTP 请求支持，用于处理 SSE（Server-Sent Events）等流式响应
///
/// ## 基本用法
///
/// ```auto
/// use http_stream: { http_get_stream, http_stream_next, http_stream_is_done }
///
/// fn main() ! {
///     // 创建流式请求
///     let stream = http_get_stream("https://api.example.com/events")
///
///     // 读取流事件
///     while http_stream_is_done(stream) == 0 {
///         let chunk = http_stream_next(stream)
///         say(chunk)
///     }
/// }
/// ```

// ═══════════════════════════════════════════════════════════════════════
// HTTPStream 类型
// ═══════════════════════════════════════════════════════════════════════

/// HTTP 流式响应类型
///
/// 封装了底层的 HTTP 连接和解析状态
type HTTPStream

// ═══════════════════════════════════════════════════════════════════════
// 流式请求函数
// ═══════════════════════════════════════════════════════════════════════

/// 创建流式 HTTP GET 请求
///
/// 向指定 URL 发送 GET 请求，并返回一个流式响应句柄
/// 注意：当前版本为简化实现，完整版本将支持真正的 SSE 流式解析
///
/// # 参数
/// - `url`: 请求的 URL
///
/// # 返回
/// HTTPStream 句柄
///
/// # 示例
/// ```auto
/// let stream = http_get_stream("https://api.example.com/stream")
/// ```
#[vm]
#[pub]
fn http_get_stream(url str) HTTPStream

/// 创建流式 HTTP POST 请求
///
/// 向指定 URL 发送 POST 请求，并返回一个流式响应句柄
/// 注意：当前版本为简化实现
///
/// # 参数
/// - `url`: 请求的 URL
/// - `body`: 请求体内容
///
/// # 返回
/// HTTPStream 句柄
///
/// # 示例
/// ```auto
/// let stream = http_post_stream("https://api.example.com/stream", '{"data": "test"}')
/// ```
#[vm]
#[pub]
fn http_post_stream(url str, body str) HTTPStream

/// Create a streaming HTTP POST request with custom headers
///
/// Sends a POST request with custom headers (e.g. Authorization, Content-Type)
/// and returns a streaming response handle for reading chunks.
///
/// # Parameters
/// - `url`: Request URL
/// - `body`: Request body (JSON string)
/// - `headers`: JSON object of headers, e.g. `'{"Authorization": "Bearer xxx"}'`
///
/// # Returns
/// HTTPStream handle
///
/// # Example
/// ```auto
/// let headers = '{"Authorization": "Bearer sk-xxx", "Content-Type": "application/json"}'
/// let stream = http_post_stream_with_headers("https://api.example.com/v1/chat", '{"model":"gpt-4"}', headers)
/// ```
#[vm]
#[pub]
fn http_post_stream_with_headers(url str, body str, headers str) HTTPStream

// ═══════════════════════════════════════════════════════════════════════
// 流操作函数
// ═══════════════════════════════════════════════════════════════════════

/// 读取下一个事件
///
/// 从流中读取下一个数据块或事件
/// 注意：当前版本为简化实现，直接返回 "[DONE]" 标记
///
/// # 参数
/// - `stream`: HTTPStream 句柄
///
/// # 返回
/// 下一个事件的内容，或 "[DONE]" 如果流已完成
///
/// # 示例
/// ```auto
/// let chunk = http_stream_next(stream)
/// if chunk == "[DONE]" {
///     say("Stream completed")
/// } else {
///     say(chunk)
/// }
/// ```
#[vm]
#[pub]
fn http_stream_next(stream HTTPStream) str

/// 检查流是否完成
///
/// 检查流式响应是否已经完成
///
/// # 参数
/// - `stream`: HTTPStream 句柄
///
/// # 返回
/// 1 如果流已完成，0 如果流仍然活跃
///
/// # 示例
/// ```auto
/// if http_stream_is_done(stream) == 1 {
///     say("Stream is done")
/// }
/// ```
#[vm]
#[pub]
fn http_stream_is_done(stream HTTPStream) int

/// 关闭流
///
/// 关闭流式连接并释放资源
///
/// # 参数
/// - `stream`: HTTPStream 句柄
///
/// # 示例
/// ```auto
/// http_stream_close(stream)
/// ```
#[vm]
#[pub]
fn http_stream_close(stream HTTPStream) void

// ═══════════════════════════════════════════════════════════════════════
// 高级用法示例
// ═══════════════════════════════════════════════════════════════════════

/// 流式请求循环示例
///
/// ```auto
/// use http_stream: { http_get_stream, http_stream_next, http_stream_is_done }
///
/// fn process_stream(url str) ! {
///     let stream = http_get_stream(url)
///     mut content = ""
///
///     // 读取所有流事件
///     while http_stream_is_done(stream) == 0 {
///         let chunk = http_stream_next(stream)
///
///         // 检查完成标记
///         if chunk == "[DONE]" {
///             break
///         }
///
///         // 累积内容
///         content += chunk
///     }
///
///     say("Final content:")
///     say(content)
/// }
/// ```
