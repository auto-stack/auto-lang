/// Env module - Environment variable operations
///
/// This module provides access to system environment variables.

/// Get an environment variable value
/// Returns the value if set, or empty string if not found
/// Example: let home = get("HOME")
#[pub]
fn get(key str) str;

/// Set an environment variable
/// Example: set("DEBUG", "1")
#[pub]
fn set(key str, value str);

/// Remove an environment variable
/// Example: remove("DEBUG")
#[pub]
fn remove(key str);
