# Parity workspace build artifacts

# Cargo build output
target/

# Cargo.lock for the parity tool itself is tracked separately; lock files for
# standalone test crates under libs/ are also fine to ignore.
Cargo.lock

# Generated by auto trans (a2r backend) next to each .at source
*.a2r.rs

# a2r per-test build directory created by the parity runner
libs/*/build_a2r/

# Rust test crate build output (defensive — root .gitignore already covers target/)
libs/*/tests/rust/target/
