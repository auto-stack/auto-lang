/// http_client_sync tests — POST to mock server, assert response body — TAP.
// Requires mock-server running on 127.0.0.1:18080 (start it first).
// Test names EXACTLY mirror the Rust oracle in tests/rust/tests/http_client_sync.rs.
use auto.http_client_sync: post_echo

fn tap_ok(n int, name str) {
    print("ok " + n.to(str) + " - " + name)
}

fn tap_not_ok(n int, name str, diag str) {
    print("not ok " + n.to(str) + " - " + name + " # " + diag)
}

fn check(n int, name str, actual str, expected str) {
    if actual == expected {
        tap_ok(n, name)
    } else {
        tap_not_ok(n, name, "got \"" + actual + "\" expected \"" + expected + "\"")
    }
}

fn main() {
    // The mock server echoes a fixed body regardless of the request body.
    var resp = post_echo("{\"hello\":\"auto\"}")
    check(1, "test_post_echo_basic", resp, "{\"echo\":\"ok\"}")

    // Different request body — same fixed response from the mock.
    resp = post_echo("anything")
    check(2, "test_post_echo_fixed_response", resp, "{\"echo\":\"ok\"}")

    // Empty body.
    resp = post_echo("")
    check(3, "test_post_echo_empty_body", resp, "{\"echo\":\"ok\"}")
}
