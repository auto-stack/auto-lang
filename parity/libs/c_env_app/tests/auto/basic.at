/// c_env_app tests — 环境变量消费者 TAP 断言。
///
/// 测试名镜像 Rust oracle（tests/rust/tests/c_env_app.rs）。
///
/// 确定性：每端用唯一 key（C_ENV_APP_TEST_*）+ 固定值，测"本进程内
/// set→get 往返"行为模式。三端各自独立进程，互不干扰。
///
/// 为彻底规避 a2r 转译器两条已知怪癖（见 c_fs_app.at 注记：owned str 变量
/// 登记为 StrSlice；用户函数的内联拼接参数不自动 .as_str()），所有 key 都
/// 用字符串字面量直接传递（无拼接、无变量），既清晰又在三端完全一致。
use auto.c_env_app: set_and_get, get_missing, get_or_value
use auto.env

fn tap_ok(n int, name str) {
    print("ok " + n.to(str) + " - " + name)
}

fn tap_not_ok(n int, name str, diag str) {
    print("not ok " + n.to(str) + " - " + name + " # " + diag)
}

fn check_str(n int, name str, actual str, expected str) {
    if actual == expected {
        tap_ok(n, name)
    } else {
        tap_not_ok(n, name, "got [" + actual + "] want [" + expected + "]")
    }
}

fn main() {
    // set_and_get 往返（确定性：本进程内 set 一定可见）
    check_str(1, "test_set_get_basic", set_and_get("C_ENV_APP_TEST_A", "hello"), "hello")
    check_str(2, "test_set_get_unicode", set_and_get("C_ENV_APP_TEST_B", "你好"), "你好")
    check_str(3, "test_set_get_empty", set_and_get("C_ENV_APP_TEST_C", ""), "")
    check_str(4, "test_set_get_overwrite", set_and_get("C_ENV_APP_TEST_A", "second"), "second")

    // get_missing：用一个极不可能存在的 key，预期空串
    check_str(5, "test_get_missing", get_missing("C_ENV_APP_TEST_NOPE_XYZ_9999"), "")

    // get_or：先 set 再 get_or（存在）
    env.set("C_ENV_APP_TEST_D", "realvalue")
    check_str(6, "test_get_or_exists", get_or_value("C_ENV_APP_TEST_D", "fallback"), "realvalue")

    // get_or：不存在返回 default
    check_str(7, "test_get_or_missing", get_or_value("C_ENV_APP_TEST_NOPE_OR_9999", "fallback"), "fallback")
}
