// ---------------------------------------------------------------------------
// One SHA-256 compression round. Reads W (via w_get) and the working variables
// a..h (passed by reference through globals A,B,C,D,E,F,G,H), updates them.
// ---------------------------------------------------------------------------

var A int = 0
var B int = 0
var C int = 0
var D int = 0
var E int = 0
var F int = 0
var G int = 0
var H int = 0

/// Process one 64-byte block. The block's 64 bytes must already be loaded into
/// the B0..B63 window via b_set. Updates the H0..H7 state globals in place.
var H0 int = 0
var H1 int = 0
var H2 int = 0
var H3 int = 0
var H4 int = 0
var H5 int = 0
var H6 int = 0
var H7 int = 0

/// Load the 16 big-endian words from the 64-byte block window into W[0..15],
/// then expand W[16..63].
fn expand_block() {
    var t int = 0
    while t < 16 {
        var b0 int = b_get(t * 4)
        var b1 int = b_get(t * 4 + 1)
        var b2 int = b_get(t * 4 + 2)
        var b3 int = b_get(t * 4 + 3)
        var w int = mk32(b0, b1, b2, b3)
        w_set(t, w)
        t = t + 1
    }
    while t < 64 {
        var wt16 int = w_get(t - 16)
        var wt7 int = w_get(t - 7)
        var s0 int = small0(wt16)
        var s1 int = small1(wt7)
        var w2 int = w_get(t - 2)
        var s1b int = small1(w2)
        var w15 int = w_get(t - 15)
        var s0b int = small0(w15)
        var val int = add32(w_get(t - 16), s0b)
        val = add32(val, w_get(t - 7))
        val = add32(val, s1b)
        w_set(t, val)
        t = t + 1
    }
}

/// Run the 64 rounds of the compression function over the current W, mixing
/// the eight working variables a..h.
fn compress() {
    A = H0
    B = H1
    C = H2
    D = H3
    E = H4
    F = H5
    G = H6
    H = H7
    var i int = 0
    while i < 64 {
        var s1 int = big1(E)
        var chv int = ch(E, F, G)
        var ki int = k_at(i)
        var wi int = w_get(i)
        var t1 int = add32(H, s1)
        t1 = add32(t1, chv)
        t1 = add32(t1, ki)
        t1 = add32(t1, wi)
        var s0 int = big0(A)
        var majv int = maj(A, B, C)
        var t2 int = add32(s0, majv)
        H = G
        G = F
        F = E
        E = add32(D, t1)
        D = C
        C = B
        B = A
        A = add32(t1, t2)
        i = i + 1
    }
    H0 = add32(H0, A)
    H1 = add32(H1, B)
    H2 = add32(H2, C)
    H3 = add32(H3, D)
    H4 = add32(H4, E)
    H5 = add32(H5, F)
    H6 = add32(H6, G)
    H7 = add32(H7, H)
}

// ---------------------------------------------------------------------------
// Final byte <-> hex helpers.
// ---------------------------------------------------------------------------

/// Append the two lowercase hex digits of byte b (0..255) to sb.
fn append_hex_byte(sb StringBuilder, b int) {
    var digits str = "0123456789abcdef"
    var hi int = b.shr(4)
    var lo int = b.and(15)
    var c0 int = digits.char_at(hi)
    var c1 int = digits.char_at(lo)
    sb.append_char(c0)
    sb.append_char(c1)
}

/// Append the eight hex digits of 32-bit word w to sb (big-endian).
/// Inlined byte-by-byte (no nested helper call) because passing a freshly
/// computed int through an extra call frame can corrupt the value in this VM.
fn append_hex_word(sb StringBuilder, w int) {
    var digits str = "0123456789abcdef"
    // byte 0 = (w >> 24) & 0xff
    var sh0 int = w.shr(24)
    var b0 int = sh0.and(255)
    var h0 int = b0.shr(4)
    var l0 int = b0.and(15)
    sb.append_char(digits.char_at(h0))
    sb.append_char(digits.char_at(l0))
    // byte 1 = (w >> 16) & 0xff
    var sh1 int = w.shr(16)
    var b1 int = sh1.and(255)
    var h1 int = b1.shr(4)
    var l1 int = b1.and(15)
    sb.append_char(digits.char_at(h1))
    sb.append_char(digits.char_at(l1))
    // byte 2 = (w >> 8) & 0xff
    var sh2 int = w.shr(8)
    var b2 int = sh2.and(255)
    var h2 int = b2.shr(4)
    var l2 int = b2.and(15)
    sb.append_char(digits.char_at(h2))
    sb.append_char(digits.char_at(l2))
    // byte 3 = w & 0xff
    var b3 int = w.and(255)
    var h3 int = b3.shr(4)
    var l3 int = b3.and(15)
    sb.append_char(digits.char_at(h3))
    sb.append_char(digits.char_at(l3))
}

// ---------------------------------------------------------------------------
// The public entry point.
// ---------------------------------------------------------------------------

/// Compute the SHA-256 hash of `input` and return the 64-char lowercase hex
/// digest. The input is processed as a sequence of bytes (via `char_at`, which
/// for ASCII inputs is identical to the UTF-8 byte sequence).
fn sha256(input str) str {
    // Initial hash values H0..H7 (FIPS 180-4), built from bytes.
    H0 = mk32(106, 9, 230, 103)    // 0x6a09e667
    H1 = mk32(187, 103, 174, 133)  // 0xbb67ae85
    H2 = mk32(60, 110, 243, 114)   // 0x3c6ef372
    H3 = mk32(165, 79, 245, 58)    // 0xa54ff53a
    H4 = mk32(81, 14, 82, 127)     // 0x510e527f
    H5 = mk32(155, 5, 104, 140)    // 0x9b05688c
    H6 = mk32(31, 131, 217, 171)   // 0x1f83d9ab
    H7 = mk32(91, 224, 205, 25)    // 0x5be0cd19

    var n int = input.len()
    // bit length of the message (mod 2^64). Held as a single 32-bit word for
    // the low 32 bits, which is more than enough for inputs up to ~512 MB.
    // We compute it as n*8 mod 2^32; n itself may be large but for the test
    // vectors n is tiny, so n*8 fits comfortably below 2^31.
    var bitlen int = n * 8

    // Walk the message in 64-byte blocks. For each block we need 64 bytes:
    // the first blocks come entirely from the message; the final block(s)
    // contain the 0x80 padding, zero fill, and the 64-bit big-endian length.
    var pos int = 0
    // Total padded length: smallest multiple of 64 that leaves 8 bytes for
    // the length suffix after the 0x80 marker.
    //   if (n mod 64) < 56 -> one block of padding; else two.
    var rem int = n % 64
    var total int = n + 64 - rem
    if rem >= 56 {
        total = n + 128 - rem
    }

    while pos < total {
        // Load the 64-byte block window B0..B63 from the padded message.
        var j int = 0
        while j < 64 {
            var idx int = pos + j
            var bv int = 0
            if idx < n {
                bv = input.char_at(idx)
            } else {
                if idx == n {
                    bv = 128
                } else {
                    // last 8 bytes carry the big-endian bit length; the rest
                    // stay zero. bit length occupies bytes [total-8, total).
                    var dist int = total - idx
                    if dist <= 8 {
                        // byte = (bitlen >> ((dist-1)*8)) & 0xff
                        // NOTE: the VM's `.shr(n)` is `u32::wrapping_shr`, so a
                        // shift by >= 32 wraps to a shift by (n mod 32) instead
                        // of yielding 0. For the 64-bit length encoding we must
                        // therefore treat any shift >= 32 as producing 0 (the
                        // high 32 bits of the length are always zero for inputs
                        // under ~512 MB, which covers all test vectors).
                        var sh int = dist - 1
                        var shf int = sh * 8
                        if shf < 32 {
                            var shifted int = bitlen.shr(shf)
                            bv = shifted.and(255)
                        } else {
                            bv = 0
                        }
                    } else {
                        bv = 0
                    }
                }
            }
            b_set(j, bv)
            j = j + 1
        }
        expand_block()
        compress()
        pos = pos + 64
    }

    // Emit H0..H7 big-endian as the 64-char hex digest.
    var sb StringBuilder = StringBuilder.new(64)
    append_hex_word(sb, H0)
    append_hex_word(sb, H1)
    append_hex_word(sb, H2)
    append_hex_word(sb, H3)
    append_hex_word(sb, H4)
    append_hex_word(sb, H5)
    append_hex_word(sb, H6)
    append_hex_word(sb, H7)
    return sb.build()
}
