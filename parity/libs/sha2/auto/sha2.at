/// sha2 library: SHA-256 hash.
///
/// Replicates the input -> hex-digest mapping of the Rust `sha2` crate
/// v0.10.8 (`Sha256`) for ASCII / byte-string inputs.
///
///   `sha256(input str) str` -> 64-char lowercase hex digest.
///
/// ## The 32-bit-unsigned-in-a-signed-VM problem (and its solution).
///
/// SHA-256 is defined over 32-bit *unsigned* words (`u32`), using addition
/// mod 2^32, logical right-shift, right-rotation, and AND/OR/XOR/NOT. The
/// Auto VM has only a signed `int` type — there is no `uint`. This module
/// proves that the signed `int` is nonetheless sufficient, because:
///
///   1. The VM's `int` bit pattern is the full 32-bit two's-complement
///      representation. A value whose top bit is set (e.g. `0x80000000`) is
///      carried correctly even though it reads back as a negative number.
///   2. Integer addition wraps mod 2^32 exactly: `0x7FFFFFFF + 1` yields the
///      bit pattern `0x80000000`, and `0x80000000 + 0x80000000` yields `0`.
///      No manual modular reduction is needed.
///   3. `.shr(n)` is a LOGICAL (zero-filling, unsigned) right shift even when
///      the operand's top bit is set — which is precisely what SHA-256 needs.
///      (`.sar(n)`, the arithmetic shift, exists but is NOT used here.)
///   4. `.and`, `.or`, `.xor` operate on the full 32-bit pattern.
///
/// So every SHA-256 word is held as a plain `int`, and its bit pattern *is*
/// the correct u32 value. We never need to print these as decimal; the only
/// place the unsigned value matters is the final byte extraction, which reads
/// the four bytes via `.shr(24).and(255)`, `.shr(16).and(255)`, etc.
///
/// ## Load-bearing VM workarounds (the same family as base64/regex/serde_json).
///
///   * **No bitwise-operator chaining.** `x.shr(8).and(15)` miscomputes; every
///     native bitwise call must be applied to a separately-named `let`/`var`.
///   * **No 32-bit literals.** Hex literals `>= 0x80000000` parse to `0`, and
///     decimal literals `>= 2^31` also fail. Every K/H constant is built from
///     its four bytes via `mk32(b0,b1,b2,b3)` (shifts + ors), where each byte
///     is a small positive literal in `[0,255]`.
///   * **No arrays.** The 64-entry round-constant table K and the 64-entry
///     message schedule W are surfaced through accessor functions (`k_at`,
///     `w_at`) backed by module-level `var int` globals plus set/get helpers,
///     since the VM has no array/Vec type and module-level `const` is not
///     reliably visible across calls.
///   * **`str.char_at(i)` returns the code point as `int`** (not a one-char
///     string), which is exactly what byte extraction from the message needs.
///   * **Strings are UTF-8.** `char_at` indexes code points; for ASCII inputs
///     (all NIST test vectors) code points == bytes, matching the Rust oracle
///     (`input.as_bytes()`). Non-ASCII inputs are out of scope.

// ---------------------------------------------------------------------------
// 32-bit unsigned helpers (operate on the bit pattern of a signed int).
// ---------------------------------------------------------------------------

/// Build a 32-bit word from four bytes (big-endian). Each byte is 0..255.
fn mk32(b0 int, b1 int, b2 int, b3 int) int {
    var s0 int = b0.shl(24)
    var s1 int = b1.shl(16)
    var s2 int = b2.shl(8)
    var r int = s0.or(s1)
    r = r.or(s2)
    r = r.or(b3)
    return r
}

/// Logical right-rotate of a 32-bit word by n bits (n in 1..31).
///   rotr(x,n) = (x >> n) | (x << (32-n))   all mod 2^32.
fn rotr(x int, n int) int {
    var hi int = x.shr(n)
    var m int = 32 - n
    var lo int = x.shl(m)
    var r int = hi.or(lo)
    return r
}

/// Ch(x,y,z) = (x & y) ^ (~x & z).
fn ch(x int, y int, z int) int {
    var a int = x.and(y)
    var nx int = x.not()
    var b int = nx.and(z)
    var r int = a.xor(b)
    return r
}

/// Maj(x,y,z) = (x & y) ^ (x & z) ^ (y & z).
fn maj(x int, y int, z int) int {
    var a int = x.and(y)
    var b int = x.and(z)
    var c int = y.and(z)
    var r int = a.xor(b)
    r = r.xor(c)
    return r
}

/// BigSigma0(x) = rotr(x,2) ^ rotr(x,13) ^ rotr(x,22).
fn big0(x int) int {
    var a int = rotr(x, 2)
    var b int = rotr(x, 13)
    var c int = rotr(x, 22)
    var r int = a.xor(b)
    r = r.xor(c)
    return r
}

/// BigSigma1(x) = rotr(x,6) ^ rotr(x,11) ^ rotr(x,25).
fn big1(x int) int {
    var a int = rotr(x, 6)
    var b int = rotr(x, 11)
    var c int = rotr(x, 25)
    var r int = a.xor(b)
    r = r.xor(c)
    return r
}

/// SmallSigma0(x) = rotr(x,7) ^ rotr(x,18) ^ (x >> 3).
fn small0(x int) int {
    var a int = rotr(x, 7)
    var b int = rotr(x, 18)
    var c int = x.shr(3)
    var r int = a.xor(b)
    r = r.xor(c)
    return r
}

/// SmallSigma1(x) = rotr(x,17) ^ rotr(x,19) ^ (x >> 10).
fn small1(x int) int {
    var a int = rotr(x, 17)
    var b int = rotr(x, 19)
    var c int = x.shr(10)
    var r int = a.xor(b)
    r = r.xor(c)
    return r
}

/// Add two 32-bit words mod 2^32 (the VM's `+` already wraps correctly).
fn add32(a int, b int) int {
    return a + b
}

// ---------------------------------------------------------------------------
// Round-constant table K (64 entries). No arrays in the VM, so each entry is
// returned by `k_at(i)` via an explicit ladder. The byte literals come from
// the FIPS 180-4 K table (each constant split into its four big-endian bytes
// because literals >= 2^31 cannot be written directly).
// ---------------------------------------------------------------------------

fn k_at(i int) int {
    if i == 0 { return mk32(66, 138, 47, 152) }
    if i == 1 { return mk32(113, 55, 68, 145) }
    if i == 2 { return mk32(181, 192, 251, 207) }
    if i == 3 { return mk32(233, 181, 219, 165) }
    if i == 4 { return mk32(57, 86, 194, 91) }
    if i == 5 { return mk32(89, 241, 17, 241) }
    if i == 6 { return mk32(146, 63, 130, 164) }
    if i == 7 { return mk32(171, 28, 94, 213) }
    if i == 8 { return mk32(216, 7, 170, 152) }
    if i == 9 { return mk32(18, 131, 91, 1) }
    if i == 10 { return mk32(36, 49, 133, 190) }
    if i == 11 { return mk32(85, 12, 125, 195) }
    if i == 12 { return mk32(114, 190, 93, 116) }
    if i == 13 { return mk32(128, 222, 177, 254) }
    if i == 14 { return mk32(155, 220, 6, 167) }
    if i == 15 { return mk32(193, 155, 241, 116) }
    if i == 16 { return mk32(228, 155, 105, 193) }
    if i == 17 { return mk32(239, 190, 71, 134) }
    if i == 18 { return mk32(15, 193, 157, 198) }
    if i == 19 { return mk32(36, 12, 161, 204) }
    if i == 20 { return mk32(45, 233, 44, 111) }
    if i == 21 { return mk32(74, 116, 132, 170) }
    if i == 22 { return mk32(92, 176, 169, 220) }
    if i == 23 { return mk32(118, 249, 136, 218) }
    if i == 24 { return mk32(152, 62, 81, 82) }
    if i == 25 { return mk32(168, 49, 198, 109) }
    if i == 26 { return mk32(176, 3, 39, 200) }
    if i == 27 { return mk32(191, 89, 127, 199) }
    if i == 28 { return mk32(198, 224, 11, 243) }
    if i == 29 { return mk32(213, 167, 145, 71) }
    if i == 30 { return mk32(6, 202, 99, 81) }
    if i == 31 { return mk32(20, 41, 41, 103) }
    if i == 32 { return mk32(39, 183, 10, 133) }
    if i == 33 { return mk32(46, 27, 33, 56) }
    if i == 34 { return mk32(77, 44, 109, 252) }
    if i == 35 { return mk32(83, 56, 13, 19) }
    if i == 36 { return mk32(101, 10, 115, 84) }
    if i == 37 { return mk32(118, 106, 10, 187) }
    if i == 38 { return mk32(129, 194, 201, 46) }
    if i == 39 { return mk32(146, 114, 44, 133) }
    if i == 40 { return mk32(162, 191, 232, 161) }
    if i == 41 { return mk32(168, 26, 102, 75) }
    if i == 42 { return mk32(194, 75, 139, 112) }
    if i == 43 { return mk32(199, 108, 81, 163) }
    if i == 44 { return mk32(209, 146, 232, 25) }
    if i == 45 { return mk32(214, 153, 6, 36) }
    if i == 46 { return mk32(244, 14, 53, 133) }
    if i == 47 { return mk32(16, 106, 160, 112) }
    if i == 48 { return mk32(25, 164, 193, 22) }
    if i == 49 { return mk32(30, 55, 108, 8) }
    if i == 50 { return mk32(39, 72, 119, 76) }
    if i == 51 { return mk32(52, 176, 188, 181) }
    if i == 52 { return mk32(57, 28, 12, 179) }
    if i == 53 { return mk32(78, 216, 170, 74) }
    if i == 54 { return mk32(91, 156, 202, 79) }
    if i == 55 { return mk32(104, 46, 111, 243) }
    if i == 56 { return mk32(116, 143, 130, 238) }
    if i == 57 { return mk32(120, 165, 99, 111) }
    if i == 58 { return mk32(132, 200, 120, 20) }
    if i == 59 { return mk32(140, 199, 2, 8) }
    if i == 60 { return mk32(144, 190, 255, 250) }
    if i == 61 { return mk32(164, 80, 108, 235) }
    if i == 62 { return mk32(190, 249, 163, 247) }
    return mk32(198, 113, 120, 242)
}

