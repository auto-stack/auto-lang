/// url parse tests — scheme / host / path extraction + error cases.
/// TAP output format. Names mirror the Rust oracle in
/// tests/rust/tests/url.rs so the parity framework can compare three-way.
///
/// Plan 348 cleanup: `parse()` now returns `Result[Url, str]`. The Ok cases
/// read struct fields directly (exercising the B1 fix — a `Url` crosses the
/// module boundary through `Ok(...)` with readable fields); the Err cases
/// assert that parsing failed (DIV-URL-VM-2 still corrupts the Err string, so
/// the message text is not inspected, only Ok-vs-Err).
use auto.url: parse, scheme, host, path

fn tap_ok(n int, name str) {
    print("ok " + n.to(str) + " - " + name)
}

fn tap_not_ok(n int, name str, diag str) {
    print("not ok " + n.to(str) + " - " + name + " # " + diag)
}

fn check_str(n int, name str, actual str, expected str) {
    if actual == expected {
        tap_ok(n, name)
    } else {
        tap_not_ok(n, name, "got \"" + actual + "\" expected \"" + expected + "\"")
    }
}

fn check_ok(n int, name str, ok bool) {
    if ok {
        tap_ok(n, name)
    } else {
        tap_not_ok(n, name, "expected Ok but got Err")
    }
}

fn check_err(n int, name str, ok bool) {
    if ok {
        tap_not_ok(n, name, "expected Err but got Ok")
    } else {
        tap_ok(n, name)
    }
}

fn main() {
    // ---- scheme ----
    check_str(1, "test_scheme_http", scheme("http://example.com/path"), "http")
    check_str(2, "test_scheme_https", scheme("https://example.com/path"), "https")
    check_str(3, "test_scheme_ftp", scheme("ftp://files.example.com"), "ftp")
    check_str(4, "test_scheme_uppercase_lowered", scheme("HTTP://Example.COM/p"), "http")

    // ---- host ----
    check_str(5, "test_host_simple", host("http://example.com/path"), "example.com")
    check_str(6, "test_host_with_port_stripped", host("http://example.com:8080/path"), "example.com")
    check_str(7, "test_host_localhost", host("http://localhost:3000/"), "localhost")

    // ---- path ----
    check_str(8, "test_path_simple", path("http://example.com/path"), "/path")
    check_str(9, "test_path_multi_segment", path("http://example.com/a/b/c"), "/a/b/c")
    check_str(10, "test_path_empty_normalised_to_root", path("http://example.com"), "/")
    check_str(11, "test_path_root", path("http://example.com/"), "/")

    // ---- parse validation ----
    // Each case inspects the Result via an `is` block. The Ok arms read the
    // `scheme` field off the returned Url (exercises B1: the struct crosses
    // the module boundary through Result Ok with readable fields). The
    // `okNN` boolean is true when the Ok arm fired with the expected scheme
    // (for Ok cases) or false otherwise (for Err cases, where check_err
    // wants false).
    var r12 = parse("http://example.com/path")
    var ok12 bool = false
    is r12 {
        Ok(u) -> { ok12 = (u.scheme == "http") }
        Err(e) -> { ok12 = false }
    }
    check_ok(12, "test_parse_valid_http", ok12)

    var r13 = parse("https://example.com")
    var ok13 bool = false
    is r13 {
        Ok(u) -> { ok13 = (u.scheme == "https") }
        Err(e) -> { ok13 = false }
    }
    check_ok(13, "test_parse_valid_https", ok13)

    // Err cases: okNN stays false (Ok arm never fires). check_err wants false.
    var r14 = parse("example.com/path")
    var ok14 bool = false
    is r14 {
        Ok(u) -> { ok14 = true }
        Err(e) -> { ok14 = false }
    }
    check_err(14, "test_parse_missing_scheme_separator", ok14)

    var r15 = parse("")
    var ok15 bool = false
    is r15 {
        Ok(u) -> { ok15 = true }
        Err(e) -> { ok15 = false }
    }
    check_err(15, "test_parse_empty_string", ok15)

    var r16 = parse("://example.com")
    var ok16 bool = false
    is r16 {
        Ok(u) -> { ok16 = true }
        Err(e) -> { ok16 = false }
    }
    check_err(16, "test_parse_only_separator", ok16)
}
