// Ext — Extending existing types with new methods
//
// Use `ext` to add methods to types defined elsewhere.

type Vec2 {
    x float
    y float
}

ext Vec2 {
    fn length(self) float {
        return self.x * self.x + self.y * self.y
    }

    fn dot(self, other Vec2) float {
        return self.x * other.x + self.y * other.y
    }
}

fn main() {
    let v = Vec2 { x: 3.0, y: 4.0 }
    print(v.length())

    let u = Vec2 { x: 1.0, y: 0.0 }
    print(v.dot(u))
}
