// Error Function — Functions with error return types
//
// Functions can return Result types to indicate success or failure.

fn safe_divide(a int, b int) !int {
    if b == 0 {
        return Err("division by zero")
    }
    return a / b
}

fn main() {
    let result = safe_divide(10, 3)
    print(result)

    let err_result = safe_divide(10, 0)
    print(err_result)
}
