// Error Function — `!` error-returning functions
//
// Functions marked with `!` can propagate errors to the caller.
// Inside a `!` function, use `.?` to propagate errors.

fn read_config(path str) !str {
    let content = read_file(path).?
    return content
}

fn main() {
    let result = read_config("config.txt")
    is result {
        Ok(data) -> print(data)
        Err(e) -> print(f"Failed to read config: $e")
    }
}
