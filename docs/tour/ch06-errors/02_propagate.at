// Error Propagation — `.?` operator
//
// The `.?` operator unwraps an Ok value or propagates the Err upward.

fn safe_divide(a int, b int) !int {
    if b == 0 {
        return Err("division by zero")
    }
    return a / b
}

fn compute(a int, b int) !int {
    let quotient = safe_divide(a, b).?
    return quotient * 2
}

fn main() {
    let r1 = compute(10, 2)
    print(r1)

    let r2 = compute(10, 0)
    print(r2)
}
