// Annotations — Function and type annotations
//
// Auto supports #[...] annotations for compiler directives.
// Common annotations: #[vm], #[c], #[rs], #[test].

fn annotated_demo(x int) int {
    return x + 1
}

fn main() {
    let result = annotated_demo(5)
    print(result)

    print("Annotations: #[vm], #[c], #[rs], #[test]")
    print("Use #[vm] for VM-implemented functions")
    print("Use #[c] for C-transpiled functions")
}
