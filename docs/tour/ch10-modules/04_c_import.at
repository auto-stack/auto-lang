// C Import — Using C libraries
//
// Use `use c <header.h>` to import C headers for FFI interop.
// This example shows the concept; actual C imports require
// the C transpiler target.

fn main() {
    print("C headers are imported with: use c <stdio.h>")
    print("C FFI enables system-level programming")
    print("C functions become available after import")
}
