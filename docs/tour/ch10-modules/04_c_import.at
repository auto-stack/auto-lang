// C Import — Using C libraries
//
// Use `use c` to import C headers for FFI interop.
// Auto can call C functions directly.

// Import C standard library
use c <stdio.h>
use c <stdlib.h>
use c <string.h>

fn main() {
    // C functions are available after import
    print("C headers imported successfully")
    print("C FFI enables system-level programming")
    print("Use use c <header.h> to import C headers")
}
