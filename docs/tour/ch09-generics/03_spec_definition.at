// Spec Definition — Interface definitions
//
// `spec` defines an interface (like traits in Rust).

spec Comparable {
    fn compare(other) int
}

type Score {
    value int
}

ext Score {
    fn compare(self, other Score) int {
        return self.value - other.value
    }
}

fn main() {
    let x = Score { value: 10 }
    let y = Score { value: 20 }
    let diff = x.compare(y)
    print(diff)
}
