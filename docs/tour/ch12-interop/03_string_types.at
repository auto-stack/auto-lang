// String Types — Different string forms
//
// Auto supports regular strings, f-strings, and multi-line strings.

fn main() {
    // Regular string
    let regular = "Hello, World!"
    print(regular)

    // F-string (formatted)
    let name = "Auto"
    let formatted = f"Hello, $name!"
    print(formatted)

    // Multi-line string
    let multi = "line 1
line 2
line 3"
    print(multi)

    // Backtick string (raw, no escapes)
    let raw = `C:\Users\path`
    print(raw)
}
