// Loop & Break — Infinite loops with break
//
// `loop` creates an infinite loop. Use `break` to exit.

fn main() {
    // Simple infinite loop with break
    var i = 0
    loop {
        if i >= 5 {
            break
        }
        print(i)
        i = i + 1
    }

    // Find first number whose square > 100
    var n = 1
    for n * n <= 100 {
        n = n + 1
    }
    print(f"First number whose square > 100: $n")
}
