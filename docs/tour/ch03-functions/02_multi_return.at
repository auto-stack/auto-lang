// Multiple Returns — Returning multiple values
//
// Functions can return multiple values using tuples or by returning
// composite types like Option and Result.

fn divide(a int, b int) int {
    return a / b
}

fn min_max(a int, b int) (int, int) {
    if a < b {
        return (a, b)
    }
    return (b, a)
}

fn main() {
    let result = divide(10, 3)
    print(result)

    let (lo, hi) = min_max(7, 3)
    print(lo)
    print(hi)
}
