// Channel — Message passing between concurrent tasks
//
// Channels provide safe communication between concurrent tasks.

fn main() {
    // Channel for sending messages between tasks
    let ch = channel(10)

    // Send values
    ch.send(1)
    ch.send(2)
    ch.send(3)

    // Receive values
    let v1 = ch.recv()
    print(v1)

    let v2 = ch.recv()
    print(v2)

    // Check channel status
    print(f"Channel has ${ch.len()} pending messages")
}
