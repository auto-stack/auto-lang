// Basic Match — `is` with values and patterns
//
// Use `is` for pattern matching. Patterns use `->` arrows.

fn describe(n int) str {
    is n {
        0 -> return "zero"
        1 -> return "one"
        2 -> return "two"
    }
    return "other"
}

fn main() {
    print(describe(0))
    print(describe(1))
    print(describe(42))
}
